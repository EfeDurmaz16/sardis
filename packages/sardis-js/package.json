{
  "name": "sardis",
  "version": "2.0.0-rc.0",
  "description": "Official TypeScript SDK for Sardis — Payment OS for the Agent Economy",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./cards": {
      "types": "./dist/cards/index.d.ts",
      "import": "./dist/cards/index.js",
      "require": "./dist/cards/index.cjs"
    },
    "./ledger": {
      "types": "./dist/ledger/index.d.ts",
      "import": "./dist/ledger/index.js",
      "require": "./dist/ledger/index.cjs"
    },
    "./chain": {
      "types": "./dist/chain/index.d.ts",
      "import": "./dist/chain/index.js",
      "require": "./dist/chain/index.cjs"
    },
    "./ucp": {
      "types": "./dist/ucp/index.d.ts",
      "import": "./dist/ucp/index.js",
      "require": "./dist/ucp/index.cjs"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js",
      "require": "./dist/protocol/index.cjs"
    },
    "./compliance": {
      "types": "./dist/compliance/index.d.ts",
      "import": "./dist/compliance/index.js",
      "require": "./dist/compliance/index.cjs"
    },
    "./guardrails": {
      "types": "./dist/guardrails/index.d.ts",
      "import": "./dist/guardrails/index.js",
      "require": "./dist/guardrails/index.cjs"
    },
    "./checkout": {
      "types": "./dist/checkout/index.d.ts",
      "import": "./dist/checkout/index.js",
      "require": "./dist/checkout/index.cjs"
    },
    "./wallet": {
      "types": "./dist/wallet/index.d.ts",
      "import": "./dist/wallet/index.js",
      "require": "./dist/wallet/index.cjs"
    },
    "./ramp": {
      "types": "./dist/ramp/index.d.ts",
      "import": "./dist/ramp/index.js",
      "require": "./dist/ramp/index.cjs"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk/index.d.ts",
      "import": "./dist/ai-sdk/index.js",
      "require": "./dist/ai-sdk/index.cjs"
    },
    "./langchain": {
      "types": "./dist/langchain/index.d.ts",
      "import": "./dist/langchain/index.js",
      "require": "./dist/langchain/index.cjs"
    },
    "./mastra": {
      "types": "./dist/mastra/index.d.ts",
      "import": "./dist/mastra/index.js",
      "require": "./dist/mastra/index.cjs"
    },
    "./webhooks": {
      "types": "./dist/webhooks/index.d.ts",
      "import": "./dist/webhooks/index.js",
      "require": "./dist/webhooks/index.cjs"
    },
    "./shims/node": {
      "types": "./dist/shims/node.d.ts",
      "import": "./dist/shims/node.js",
      "require": "./dist/shims/node.cjs"
    },
    "./shims/web": {
      "types": "./dist/shims/web.d.ts",
      "import": "./dist/shims/web.js",
      "require": "./dist/shims/web.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "sardis-migrate": "./scripts/migrate.cjs"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "sardis",
    "ai-agents",
    "ai-payments",
    "agent-payments",
    "stablecoin",
    "payments",
    "blockchain",
    "usdc",
    "mpc",
    "wallet",
    "mandate",
    "ap2",
    "x402",
    "typescript",
    "sdk",
    "fintech",
    "ai-sdk",
    "vercel-ai",
    "langchain",
    "mastra"
  ],
  "author": "Sardis <sdk@sardis.sh>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EfeDurmaz16/sardis.git",
    "directory": "packages/sardis-js"
  },
  "homepage": "https://sardis.sh",
  "bugs": {
    "url": "https://github.com/EfeDurmaz16/sardis/issues"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "ai": ">=3.0.0",
    "@langchain/core": ">=0.3.0",
    "@mastra/core": ">=0.1.0",
    "react": ">=18.0.0",
    "typescript": ">=4.7.0"
  },
  "peerDependenciesMeta": {
    "ai": { "optional": true },
    "@langchain/core": { "optional": true },
    "@mastra/core": { "optional": true },
    "react": { "optional": true },
    "typescript": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.0.0",
    "msw": "^2.12.9",
    "size-limit": "^11.1.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false
}
