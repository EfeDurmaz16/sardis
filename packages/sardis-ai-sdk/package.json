{
  "name": "@sardis/ai-sdk",
  "version": "1.2.0",
  "description": "DEPRECATED — re-export shim for `sardis/ai-sdk`. Install `sardis` instead.",
  "deprecated": "Use `sardis` (which exposes `sardis/ai-sdk`) — run `npx sardis-migrate` to upgrade.",
  "keywords": [
    "ai",
    "ai-sdk",
    "vercel-ai",
    "payments",
    "agents",
    "autonomous-agents",
    "stablecoin",
    "crypto",
    "fintech",
    "sardis",
    "llm",
    "openai",
    "anthropic",
    "function-calling",
    "tools"
  ],
  "author": "Sardis <hello@sardis.sh>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EfeDurmaz16/sardis.git",
    "directory": "packages/sardis-ai-sdk"
  },
  "homepage": "https://sardis.sh",
  "bugs": {
    "url": "https://github.com/EfeDurmaz16/sardis/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    },
    "./provider": {
      "import": "./dist/provider.js",
      "types": "./dist/provider.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "sardis": "^2.0.0-rc.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "ai": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ai": "^6.0.68",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
