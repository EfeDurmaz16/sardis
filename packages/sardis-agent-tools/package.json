{
  "name": "@sardis/agent-tools",
  "version": "0.1.0",
  "description": "Sardis as a TOOL for AI agents — give-wallet / spend / issue-card / set-budget / pay-invoice verbs that route to the Sardis SDK, with a fail-closed governance gate (classify -> canonical-hash commit -> allow / requires-approval / deny) and generic LangChain / Vercel-AI / MCP adapters.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./langchain": {
      "types": "./dist/adapters/langchain.d.ts",
      "import": "./dist/adapters/langchain.js",
      "require": "./dist/adapters/langchain.cjs"
    },
    "./vercel-ai": {
      "types": "./dist/adapters/vercel-ai.d.ts",
      "import": "./dist/adapters/vercel-ai.js",
      "require": "./dist/adapters/vercel-ai.cjs"
    },
    "./mcp": {
      "types": "./dist/adapters/mcp.d.ts",
      "import": "./dist/adapters/mcp.js",
      "require": "./dist/adapters/mcp.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "sardis",
    "ai-agents",
    "agent-payments",
    "tools",
    "tool-calling",
    "langchain",
    "vercel-ai",
    "mcp",
    "governance",
    "spending-policy",
    "typescript"
  ],
  "author": "Sardis <sdk@sardis.sh>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EfeDurmaz16/sardis.git",
    "directory": "packages/sardis-agent-tools"
  },
  "homepage": "https://sardis.sh",
  "bugs": {
    "url": "https://github.com/EfeDurmaz16/sardis/issues"
  },
  "dependencies": {
    "sardis": "workspace:*",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false
}
