{
  "name": "@sardis/cli",
  "version": "1.0.0",
  "description": "CLI for Sardis - The Payment OS for the Agent Economy. Execute payments, manage wallets, and control spending policies from your terminal.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "sardis": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "keywords": [
    "sardis",
    "cli",
    "payments",
    "ai-agents",
    "fintech",
    "stablecoin",
    "usdc",
    "spending-policy",
    "virtual-cards",
    "mpc-wallet"
  ],
  "author": "Sardis <support@sardis.sh>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sardis-pay/sardis.git",
    "directory": "packages/sardis-cli-js"
  },
  "homepage": "https://sardis.sh",
  "bugs": {
    "url": "https://github.com/sardis-pay/sardis/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
