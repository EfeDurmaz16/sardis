# Optional — defaults work offline
TEMPO_RPC_URL=https://rpc.tempo.xyz
TEMPO_CHAIN_ID=4217

# Set to 1 to exercise the live-mainnet path (requires funded account)
TEMPO_LIVE=0

# Set these to use real Turnkey MPC custody (otherwise a fake client is used)
TURNKEY_API_KEY=
TURNKEY_ORG_ID=

# Set to hit the hosted Sardis policy engine instead of the in-process one
SARDIS_API_URL=
SARDIS_API_KEY=
