# Optional — defaults run offline with a fake Circle client
ARC_LIVE=0

# Required when ARC_LIVE=1:
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# Arc testnet RPC (update from https://docs.arc.network when public)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Set to hit the hosted Sardis policy engine instead of the in-process one
SARDIS_API_URL=
SARDIS_API_KEY=
