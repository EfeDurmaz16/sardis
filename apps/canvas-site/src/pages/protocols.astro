---
import Canvas from "../layouts/Canvas.astro";
const styles = `
    .proto-card {
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 22px;
      background: var(--card);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .proto-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 10px;
    }
    .proto-head h3 { font-size: 16px; margin: 0; }
    .proto-tag {
      font-family: var(--font-mono);
      font-size: 10.5px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      white-space: nowrap;
    }
    .proto-kv { display: grid; grid-template-columns: 110px 1fr; gap: 6px 12px; font-size: 12.5px; }
    .proto-kv dt { color: var(--text-muted); font-family: var(--font-mono); font-size: 11px; }
    .proto-kv dd { margin: 0; color: var(--text-secondary); }
    .proto-code {
      font-family: var(--font-mono);
      font-size: 11.5px;
      background: var(--muted);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-sm);
      padding: 10px 12px;
      white-space: pre-wrap;
      color: var(--text);
      overflow-x: auto;
    }
  `;
---

<Canvas title="13 · Multi-Protocol Gateway — Sardis Canvas" currentId="protocols">
<Fragment slot="head">
  <style is:global set:html={styles}></style>
</Fragment>

<section class="hero">
        <span class="eyebrow">Canvas 13 · Product</span>
        <h1>Multi-Protocol Gateway</h1>
        <p class="hero-lead">
          Agent payments aren't converging on one standard yet. Google, Visa, Mastercard, Coinbase,
          Circle, and Stripe each have their own protocol. Sardis speaks all of them behind a single
          orchestrator so a merchant, SDK, or agent doesn't pick a team. One <code>/pay</code> front
          door; the right verifier underneath.
        </p>
      </section>

      <section class="section" style="padding-top:0; border-top:0;">
        <div class="callout callout-info">
          <span class="callout-title">TL;DR</span>
          Eight protocols wire into the same <code>PaymentOrchestrator</code>:
          <strong>AP2</strong>, <strong>TAP</strong>, <strong>x402</strong>, <strong>A2A</strong>,
          <strong>ACP</strong>, <strong>MPP</strong> (Stripe/Tempo), <strong>ERC-8004</strong>,
          <strong>ERC-8183</strong>. Every one of them terminates at the same fail-closed gate,
          runs on the same ledger, and emits the same webhook envelope.
        </div>
      </section>

      <!-- Gateway flow -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">The gateway</div>
          <h2>One entry, many verifiers.</h2>
          <p class="text-muted" style="max-width:720px;">
            Callers signal their protocol via route (<code>/v1/ap2/...</code>,
            <code>/v1/x402/...</code>, <code>/v1/a2a/...</code>) or via headers. Each protocol has a
            dedicated verifier in <code>packages/sardis-protocol/</code>; verified intents feed into
            the same orchestrator that wallet-native calls use.
          </p>
        </div>
        <div class="diagram">
          <pre class="mermaid" is:raw>
flowchart LR
    subgraph Callers
      A1[Agent via AP2]
      A2[Visa rail · TAP]
      A3[API provider · x402]
      A4[Google A2A agent]
      A5[ACP / Stripe MPP]
      A6[On-chain ERC-8183 job]
    end

    A1 --> R1[ap2.py]
    A2 --> R2[tap.py + visa_tap_webhooks.py]
    A3 --> R3[x402.py]
    A4 --> R4[a2a.py · a2a_payments.py]
    A5 --> R5[acp.py · mpp.py]
    A6 --> R6[erc8183_policy_guard.py]

    R1 --> V[MandateVerifier]
    R2 --> V
    R3 --> V
    R4 --> V
    R5 --> V
    R6 --> V

    V --> G[PreExecutionPipeline<br/>Policy + KYC + Sanctions + Trust]
    G --> O[PaymentOrchestrator]
    O --> C[ChainExecutor · MPC · Ledger]
          </pre>
        </div>
      </section>

      <!-- Protocols: one card per -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Eight protocols</div>
          <h2>Same structure for each.</h2>
          <p class="text-muted" style="max-width:720px;">
            What it is · who runs it · when to reach for it · where Sardis implements it · the signature shape.
          </p>
        </div>

        <div class="grid grid-2">

          <!-- AP2 -->
          <div class="proto-card">
            <div class="proto-head">
              <h3>AP2 — Agent Payment Protocol</h3>
              <span class="proto-tag">consortium</span>
            </div>
            <div class="text-muted" style="font-size:13px;">
              Mandate chain protocol: <em>Intent → Cart → Payment</em>. Each mandate is signed by the
              previous actor (user authorizes agent, agent authorizes merchant, merchant authorizes rail).
              The verifier walks the whole chain, checking Ed25519 / ECDSA-P256 signatures, TTLs, and
              replay cache before the transaction is even scheduled.
            </div>
            <dl class="proto-kv">
              <dt>Who</dt><dd>Google · PayPal · Mastercard · Visa consortium</dd>
              <dt>Use when</dt><dd>B2B agent commerce · multi-party flows with human approval upstream</dd>
              <dt>Router</dt><dd><code>routers/ap2.py</code> → <code>/v1/ap2/payments/execute</code></dd>
              <dt>Verifier</dt><dd><code>sardis_protocol/verifier.py</code> · <code>mandate_cache.py</code></dd>
            </dl>
            <pre class="proto-code">POST /v1/ap2/payments/execute
&#123;
  "intent_mandate":  &#123; "user_did", "agent_did", "scope", "sig" &#125;,
  "cart_mandate":    &#123; "cart", "merchant_did", "sig" &#125;,
  "payment_mandate": &#123; "amount", "rail", "sig" &#125;
&#125;</pre>
          </div>

          <!-- TAP -->
          <div class="proto-card">
            <div class="proto-head">
              <h3>TAP — Trust Anchor Protocol</h3>
              <span class="proto-tag">visa</span>
            </div>
            <div class="text-muted" style="font-size:13px;">
              Visa's agent-identity attestation protocol. mTLS + TRID (Transaction Risk Indicator) for
              card-rail transactions. The identity piece lives in
              <code>packages/sardis-protocol/src/sardis_protocol/tap.py</code>; webhooks come in via
              <code>routers/visa_tap_webhooks.py</code>. Pairs with AP2 when Visa is the rail.
            </div>
            <dl class="proto-kv">
              <dt>Who</dt><dd>Visa</dd>
              <dt>Use when</dt><dd>Visa card rail is part of the flow (card-present or card-not-present agent purchase)</dd>
              <dt>Router</dt><dd><code>routers/visa_tap_webhooks.py</code></dd>
              <dt>Module</dt><dd><code>sardis_protocol/tap.py</code> · <code>tap_keys.py</code></dd>
            </dl>
            <pre class="proto-code">agent_id + tap_key (Ed25519)
  → challenge-response attestation
  → TRID score forwarded to Visa auth
  → rail approves / declines</pre>
          </div>

          <!-- x402 -->
          <div class="proto-card">
            <div class="proto-head">
              <h3>x402 — HTTP 402 auto-pay</h3>
              <span class="proto-tag">coinbase · circle</span>
            </div>
            <div class="text-muted" style="font-size:13px;">
              Server responds <code>402 Payment Required</code> with a payment challenge; client
              auto-pays in USDC and retries. Revives HTTP's long-dormant 402 as the canonical
              pay-per-call path for AI APIs. Sardis implements the verifier, settler, and challenge
              generator, with ERC-3009 transfer support.
            </div>
            <dl class="proto-kv">
              <dt>Who</dt><dd>Coinbase + Circle Gateway facilitators</dd>
              <dt>Use when</dt><dd>API-to-API pay-per-call · AI inference · tool marketplaces</dd>
              <dt>Router</dt><dd><code>routers/x402.py</code> → <code>/verify</code> · <code>/settle</code> · <code>/challenges</code> · <code>/dry-run</code></dd>
              <dt>Modules</dt><dd><code>x402.py</code> · <code>x402_erc3009.py</code> · <code>x402_settlement.py</code> · <code>x402_upto.py</code></dd>
            </dl>
            <pre class="proto-code">GET /expensive-endpoint
← 402 Payment Required
  &#123; "accepts": [&#123; "scheme": "exact", "asset": "USDC", "amount": "0.05" &#125;] &#125;
→ sign ERC-3009 transfer → POST /verify
→ receipt attached → retry original call</pre>
          </div>

          <!-- A2A -->
          <div class="proto-card">
            <div class="proto-head">
              <h3>A2A — Google Agent-to-Agent</h3>
              <span class="proto-tag">google</span>
            </div>
            <div class="text-muted" style="font-size:13px;">
              Google's open protocol for agents from different platforms to discover each other, trust
              each other, and transact. Sardis provides <code>/pay</code>, message envelopes, and a
              full trust-table API (peer discovery, relation CRUD, security-policy queries, audit).
            </div>
            <dl class="proto-kv">
              <dt>Who</dt><dd>Google (open)</dd>
              <dt>Use when</dt><dd>Agents from different platforms transacting</dd>
              <dt>Router</dt><dd><code>routers/a2a.py</code> + <code>routers/a2a_payments.py</code></dd>
              <dt>Key endpoints</dt><dd><code>/pay</code> · <code>/messages</code> · <code>/trust/table</code> · <code>/trust/check</code> · <code>/trust/peers</code> · <code>/trust/relations</code> · <code>/trust/security-policy</code> · <code>/trust/audit/recent</code></dd>
            </dl>
            <pre class="proto-code">POST /v1/a2a/pay
&#123; "from_agent_did", "to_agent_did", "amount", "currency", "reason" &#125;
→ trust_check(from_agent, to_agent)
→ mandate issued if trust ≥ threshold
→ settlement via Sardis orchestrator</pre>
          </div>

          <!-- ACP -->
          <div class="proto-card">
            <div class="proto-head">
              <h3>ACP — Agent Commerce Protocol</h3>
              <span class="proto-tag">emerging</span>
            </div>
            <div class="text-muted" style="font-size:13px;">
              Emerging standard for agent-mediated commerce — catalog, offer, order, settle.
              Sardis ships the router; the protocol is deliberately thin so it can ride Sardis' own
              orchestrator + ledger machinery rather than reinventing them.
            </div>
            <dl class="proto-kv">
              <dt>Who</dt><dd>Emerging · multi-vendor spec</dd>
              <dt>Use when</dt><dd>Catalog-first flows where discovery precedes payment</dd>
              <dt>Router</dt><dd><code>routers/acp.py</code></dd>
              <dt>Verbs</dt><dd>offer · order · settle · attestation · payment-proof · dispute</dd>
            </dl>
            <pre class="proto-code">POST /v1/acp/offers   — merchant posts
POST /v1/acp/orders   — agent orders
POST /v1/acp/settle   — orchestrator settles
POST /v1/acp/attest   — evidence anchored</pre>
          </div>

          <!-- MPP (Stripe / Tempo) -->
          <div class="proto-card">
            <div class="proto-head">
              <h3>MPP — Merchant Payment Protocol</h3>
              <span class="proto-tag">stripe · tempo</span>
            </div>
            <div class="text-muted" style="font-size:13px;">
              Stripe's protocol layered on Tempo (100K+ TPS EVM L1). Sessions, execute, close, policy
              evaluate/simulate, card issuance. Sardis is live on Tempo mainnet (chain_id 4217) via
              the dedicated executor in <code>packages/sardis-chain/src/sardis_chain/tempo/</code>
              and plugs MPP sessions into Sardis policy at <code>mpp_gate</code>.
            </div>
            <dl class="proto-kv">
              <dt>Who</dt><dd>Stripe + Tempo</dd>
              <dt>Use when</dt><dd>High-throughput merchant flows · card issuance at scale</dd>
              <dt>Router</dt><dd><code>routers/mpp.py</code></dd>
              <dt>Endpoints</dt><dd><code>/sessions</code> · <code>/sessions/&#123;id&#125;/execute</code> · <code>/sessions/&#123;id&#125;/close</code> · <code>/evaluate</code> · <code>/simulate</code> · <code>/cards/issue</code></dd>
            </dl>
            <pre class="proto-code">POST /v1/mpp/sessions                → create
POST /v1/mpp/sessions/&#123;id&#125;/execute   → pay
POST /v1/mpp/evaluate                → policy decision only
POST /v1/mpp/cards/issue             → issue a card</pre>
          </div>

          <!-- ERC-8004 -->
          <div class="proto-card">
            <div class="proto-head">
              <h3>ERC-8004 — Agent attestation</h3>
              <span class="proto-tag">erc</span>
            </div>
            <div class="text-muted" style="font-size:13px;">
              On-chain attestation standard for agent identity. Provides verifiable claims about
              agent code hash, operator, and capabilities. Sardis implements the reader/writer at
              <code>packages/sardis-core/src/.../erc8004.py</code>; it feeds into KYA and FIDES
              signals consumed at the gate.
            </div>
            <dl class="proto-kv">
              <dt>Who</dt><dd>ERC standards track</dd>
              <dt>Use when</dt><dd>Regulated deployments needing on-chain attestation of agent code + operator</dd>
              <dt>Module</dt><dd><code>sardis_v2_core/erc8004.py</code></dd>
              <dt>Pairs with</dt><dd>KYA lifecycle · FIDES DIDs · AGIT repo hash</dd>
            </dl>
            <pre class="proto-code">agent register → on-chain attestation
  &#123; agent_did, code_hash, operator_addr, sig &#125;
reader verifies → feeds KYA + FIDES signals</pre>
          </div>

          <!-- ERC-8183 -->
          <div class="proto-card">
            <div class="proto-head">
              <h3>ERC-8183 — On-chain policy + reputation</h3>
              <span class="proto-tag">erc</span>
            </div>
            <div class="text-muted" style="font-size:13px;">
              On-chain policy module + reputation registry + job market for agents. Three modules:
              <code>erc8183_policy_guard.py</code> (enforces policy at chain edge),
              <code>erc8183_reputation.py</code> (tracks post-trade reputation),
              <code>erc8183_job.py</code> (job lifecycle). Launched with conservative caps (1% fee,
              USDC-only, trust hooks disabled) — audit-driven relaxation path.
            </div>
            <dl class="proto-kv">
              <dt>Who</dt><dd>ERC standards track · Sardis-authored implementation</dd>
              <dt>Use when</dt><dd>On-chain agent jobs · cross-platform reputation portability</dd>
              <dt>Modules</dt><dd><code>erc8183_policy_guard.py</code> · <code>erc8183_reputation.py</code> · <code>erc8183_job.py</code></dd>
              <dt>Caps</dt><dd>≤1% fee · USDC-only · trust hooks disabled pre-audit</dd>
            </dl>
            <pre class="proto-code">Job posted → policy_guard evaluates
  → agent accepts → work → settle
  → reputation registry updates score</pre>
          </div>

        </div>
      </section>

      <!-- When to use what -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Decision matrix</div>
          <h2>When to reach for which protocol.</h2>
          <p class="text-muted" style="max-width:720px;">
            Most real deployments use two at once (e.g., AP2 for the mandate chain, x402 for the actual
            API call). The matrix below is the first-cut decision tree.
          </p>
        </div>
        <table class="data">
          <thead>
            <tr><th>Use case</th><th>Primary</th><th>Secondary</th><th>Tradeoff</th></tr>
          </thead>
          <tbody>
            <tr><td>AI agent buys an API call</td><td>x402</td><td>—</td><td>Lowest friction · assumes crypto rail · USDC only</td></tr>
            <tr><td>Agent books travel / multi-party purchase</td><td>AP2</td><td>TAP (if Visa)</td><td>Heaviest verification · strongest audit · slowest</td></tr>
            <tr><td>Two agents on different platforms pay each other</td><td>A2A</td><td>AP2</td><td>Built-in trust graph · requires peer A2A support</td></tr>
            <tr><td>Merchant wants Stripe-native billing</td><td>MPP</td><td>x402</td><td>Stripe-familiar · needs Tempo access</td></tr>
            <tr><td>Card-rail purchase from agent</td><td>TAP + AP2</td><td>—</td><td>Visa-native · requires mTLS + Visa onboarding</td></tr>
            <tr><td>On-chain job for an agent</td><td>ERC-8183</td><td>ERC-8004</td><td>Fully on-chain · permissionless · 1% cap until audit</td></tr>
            <tr><td>Need verifiable agent identity</td><td>ERC-8004</td><td>FIDES (migration 055)</td><td>Anchored · interoperable · needs operator public key</td></tr>
            <tr><td>Generic catalog + order flow</td><td>ACP</td><td>x402 for payment leg</td><td>Thin spec · rides Sardis orchestrator</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Shared primitives -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Shared primitives</div>
          <h2>What every verifier reuses.</h2>
          <p class="text-muted" style="max-width:720px;">
            The reason supporting eight protocols is tractable: they all reduce to the same three
            problems (signature verification, replay prevention, mandate archival). Sardis builds
            those once.
          </p>
        </div>
        <table class="data">
          <thead>
            <tr><th>Module</th><th>Role</th></tr>
          </thead>
          <tbody>
            <tr><td><code>sardis_protocol/verifier.py</code></td><td>Ed25519 / ECDSA-P256 / secp256k1 signature verification core.</td></tr>
            <tr><td><code>sardis_protocol/mandate_cache.py</code></td><td>Canonical mandate store — every protocol's signed payload lands here.</td></tr>
            <tr><td><code>sardis_protocol/replay_cache_redis.py</code></td><td>Redis-backed replay cache. TTL per protocol; required in prod.</td></tr>
            <tr><td><code>sardis_protocol/nonce_registry.py</code></td><td>Per-agent, per-protocol nonce tracking to defeat replay even without Redis.</td></tr>
            <tr><td><code>sardis_protocol/reason_codes.py</code></td><td>Canonical deny-reason catalog shared across protocols and audit.</td></tr>
            <tr><td><code>sardis_protocol/rate_limiter.py</code></td><td>Protocol-aware rate limiter (stricter for public protocols).</td></tr>
            <tr><td><code>sardis_protocol/payment_methods.py</code></td><td>Rail selection — USDC / ERC-3009 / Visa / card / Lightning.</td></tr>
            <tr><td><code>sardis_protocol/fides_signing.py</code></td><td>FIDES DID signing adapter used by AP2 and A2A.</td></tr>
            <tr><td><code>sardis_protocol/eas_kya.py</code></td><td>EAS (Ethereum Attestation Service) bridge for KYA facts.</td></tr>
            <tr><td><code>sardis_protocol/zkpass_transgate.py</code></td><td>zkPass TransGate — zero-knowledge claims surfaced into protocols.</td></tr>
            <tr><td><code>sardis_protocol/paladin_privacy.py</code></td><td>Paladin privacy layer for sensitive mandate fields.</td></tr>
            <tr><td><code>sardis_protocol/kleros.py</code></td><td>Kleros dispute adapter — protocol-level dispute resolution.</td></tr>
            <tr><td><code>sardis_protocol/schemas.py</code></td><td>Cross-protocol Pydantic schemas; one definition per shape.</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Endpoint surface -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Endpoint surface</div>
          <h2>Every protocol front door.</h2>
        </div>
        <table class="data">
          <thead>
            <tr><th>Protocol</th><th>Endpoint</th><th>Purpose</th></tr>
          </thead>
          <tbody>
            <tr><td>AP2</td><td><code>POST /v1/ap2/payments/execute</code></td><td>Verify mandate chain and execute.</td></tr>
            <tr><td>TAP</td><td><code>POST /v1/webhooks/visa-tap</code> (via <code>visa_tap_webhooks.py</code>)</td><td>Visa TAP event ingestion.</td></tr>
            <tr><td>x402</td><td><code>POST /v1/x402/verify</code></td><td>Verify a client-signed 402 payment payload.</td></tr>
            <tr><td>x402</td><td><code>POST /v1/x402/settle</code></td><td>Settle a verified 402 payment on-chain.</td></tr>
            <tr><td>x402</td><td><code>GET /v1/x402/settlements/&#123;payment_id&#125;</code></td><td>Settlement status lookup.</td></tr>
            <tr><td>x402</td><td><code>POST /v1/x402/dry-run</code></td><td>Server-side simulation before signing.</td></tr>
            <tr><td>x402</td><td><code>POST /v1/x402/challenges</code></td><td>Issue a 402 challenge (server-side helper).</td></tr>
            <tr><td>A2A</td><td><code>POST /v1/a2a/pay</code></td><td>Cross-platform agent payment.</td></tr>
            <tr><td>A2A</td><td><code>POST /v1/a2a/messages</code></td><td>Signed inter-agent envelopes.</td></tr>
            <tr><td>A2A</td><td><code>GET /v1/a2a/trust/table</code> · <code>/trust/peers</code> · <code>/trust/audit/recent</code></td><td>Trust graph queries.</td></tr>
            <tr><td>A2A</td><td><code>POST /v1/a2a/trust/check</code> · <code>/trust/relations</code> · <code>DELETE /trust/relations</code></td><td>Trust relation CRUD + check.</td></tr>
            <tr><td>A2A</td><td><code>GET /v1/a2a/trust/security-policy</code></td><td>Published security policy for peers.</td></tr>
            <tr><td>ACP</td><td><code>POST /v1/acp/offers</code> · <code>/orders</code> · <code>/settle</code> · <code>/attest</code></td><td>Full ACP commerce loop.</td></tr>
            <tr><td>MPP</td><td><code>POST /v1/mpp/sessions</code> · <code>/execute</code> · <code>/close</code></td><td>Stripe/Tempo session lifecycle.</td></tr>
            <tr><td>MPP</td><td><code>POST /v1/mpp/evaluate</code> · <code>/simulate</code></td><td>Policy decision without execution.</td></tr>
            <tr><td>MPP</td><td><code>POST /v1/mpp/cards/issue</code></td><td>Card issuance via Stripe Issuing bridge.</td></tr>
            <tr><td>ERC-8004</td><td>on-chain · read/write via SDK</td><td>Attestation read/write (not HTTP front door).</td></tr>
            <tr><td>ERC-8183</td><td>on-chain · Sardis-deployed modules</td><td>Policy guard / reputation / job registry.</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Source of truth -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Source of truth</div>
          <h2>Files to grep.</h2>
        </div>
        <table class="data">
          <thead>
            <tr><th>File</th><th>Owns</th></tr>
          </thead>
          <tbody>
            <tr><td><code>packages/sardis-protocol/src/sardis_protocol/</code></td><td>Verifier core, replay cache, mandate cache, nonce registry, reason codes, schemas, per-protocol helpers.</td></tr>
            <tr><td><code>packages/api/sardis_server/routes/authority/ap2.py</code></td><td>AP2 mandate-chain execute endpoint.</td></tr>
            <tr><td><code>packages/api/sardis_server/routes/providers/visa_tap_webhooks.py</code></td><td>Visa TAP webhook ingestion.</td></tr>
            <tr><td><code>packages/api/sardis_server/routes/protocol/x402.py</code></td><td>x402 verify / settle / dry-run / challenges.</td></tr>
            <tr><td><code>packages/api/sardis_server/routes/protocol/a2a.py</code></td><td>Google A2A payments + trust graph.</td></tr>
            <tr><td><code>packages/api/sardis_server/routes/protocol/a2a_payments.py</code></td><td>A2A payments helper endpoints.</td></tr>
