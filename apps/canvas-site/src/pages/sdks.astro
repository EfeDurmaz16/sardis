        <pre><code>npm i @sardis/sdk
# or
pnpm add @sardis/sdk</code></pre>

        <pre><code>import &#123; SardisClient, RateLimitError, AuthenticationError &#125; from "@sardis/sdk";

const client = new SardisClient(&#123; apiKey: process.env.SARDIS_API_KEY! &#125;);

const agent  = await client.agents.create(&#123; name: "My First Agent" &#125;);
const wallet = await client.wallets.create(&#123; agent_id: agent.agent_id, chain: "base" &#125;);

const policy = await client.policies.parse(&#123;
  text: "Max $100 per transaction, $500 per day, no gambling",
&#125;);
await client.policies.apply(&#123; wallet_id: wallet.wallet_id, policy &#125;);

try &#123;
  const payment = await client.payments.send(&#123;
    wallet_id: wallet.wallet_id,
    to: "merchant_demo",
    amount: "25.00",
    purpose: "API usage - OpenAI",
  &#125;);
  console.log(payment.status, payment.tx_id);
&#125; catch (err) &#123;
  if (err instanceof RateLimitError) &#123;
    await new Promise(r =&gt; setTimeout(r, err.retryAfter * 1000));
  &#125; else if (err instanceof AuthenticationError) &#123;
    throw err;
  &#125;
&#125;</code></pre>

