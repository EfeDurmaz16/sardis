---
import Canvas from "../layouts/Canvas.astro";
const styles = `
    .surface-tile {
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 18px 20px;
      background: var(--card);
    }
    .surface-tile .surface-label {
      font-family: var(--font-mono);
      font-size: 10.5px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 6px;
    }
    .surface-tile .surface-title { font-weight: 600; font-size: 14.5px; margin-bottom: 4px; }
    .surface-tile .surface-desc { font-size: 12.5px; color: var(--text-muted); }
    .chip-row { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 3px 8px;
      background: var(--muted);
      border: 1px solid var(--border-subtle);
      border-radius: 4px;
      color: var(--text-secondary);
    }
  `;
