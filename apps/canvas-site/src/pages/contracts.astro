---
import Canvas from "../layouts/Canvas.astro";
const styles = `
    .stat-row { display: flex; gap: 24px; flex-wrap: wrap; margin-top: 12px; }
    .stat-pill {
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 14px 18px;
      background: var(--card);
      min-width: 160px;
    }
    .stat-pill .stat-num { font-size: 22px; font-weight: 600; font-family: var(--font-mono); }
    .stat-pill .stat-label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; }
    .contract-block {
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 20px 22px;
      background: var(--card);
      margin-bottom: 14px;
    }
    .contract-block .cb-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }
    .contract-block .cb-name { font-family: var(--font-mono); font-size: 14px; font-weight: 600; }
    .cb-tags { display: flex; gap: 6px; flex-wrap: wrap; }
    .cb-tag {
      font-family: var(--font-mono);
      font-size: 10.5px;
      padding: 3px 7px;
      background: var(--muted);
      border: 1px solid var(--border-subtle);
      border-radius: 3px;
      color: var(--text-secondary);
    }
    .cb-tag.warn { background: #fff7e6; border-color: #f0d8a0; color: #7a5a10; }
    [data-theme="dark"] .cb-tag.warn { background: #332a18; border-color: #554630; color: #e6c070; }
    .cb-tag.ext { background: var(--muted); }
    .cb-body { font-size: 13px; color: var(--text-secondary); line-height: 1.55; }
    .cb-body .cb-purpose { margin-bottom: 10px; }
    .cb-body dl.defs { margin-top: 10px; }
  `;
---

<Canvas title="06 · Smart Contracts — Sardis Canvas" currentId="contracts">
<Fragment slot="head">
  <style is:global set:html={styles}></style>
</Fragment>

<section class="hero">
        <span class="eyebrow">Canvas 06 · Backend</span>
        <h1>Smart Contracts</h1>
        <p class="hero-lead">
          Sardis is deliberately thin on-chain. The heavy lifting — policy evaluation, mandate
          verification, KYC, compliance — happens off-chain where it can be iterated safely. On-chain we
          only deploy what needs public, auditable, tamper-evident behaviour: identity registries, an
          evidence anchor, an escrow-based job primitive (ERC-8183), and a refund protocol.
        </p>
      </section>

      <section class="section" style="padding-top:0; border-top:0;">
        <div class="callout callout-info">
          <span class="callout-title">TL;DR</span>
          Nine <code>.sol</code> files live under <code>contracts/src/</code>. Two are deprecated on
          purpose (<code>SardisPolicyModule</code> → Zodiac Roles; <code>SardisVerifyingPaymaster</code> →
          Circle Paymaster) — kept for reference, not deployed. The rest implement ERC-8004 (agent
          identity), ERC-8183 (job escrow), a minimal ledger anchor, and Circle's audited
          <code>RefundProtocol</code> vendored in-tree.
        </div>
        <div class="stat-row">
          <div class="stat-pill"><div class="stat-num">9</div><div class="stat-label">Contracts</div></div>
          <div class="stat-pill"><div class="stat-num">Foundry</div><div class="stat-label">Build &amp; test</div></div>
          <div class="stat-pill"><div class="stat-num">0.8.20 – 0.8.24</div><div class="stat-label">Solidity</div></div>
          <div class="stat-pill"><div class="stat-num">OpenZeppelin</div><div class="stat-label">Primitives</div></div>
          <div class="stat-pill"><div class="stat-num">ERC-8004 / 8183 / 4337</div><div class="stat-label">Standards</div></div>
        </div>
      </section>

      <!-- Design principles -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Principles</div>
          <h2>Why so little on-chain?</h2>
        </div>
        <div class="grid grid-2">
          <div class="card">
            <div class="card-title">Prefer audited standards over bespoke contracts</div>
            <div class="card-description">
              Wallet custody: Safe v1.4.1 (pre-deployed on every EVM chain, $100B+ TVL). Policy module:
              Zodiac Roles (<code>0x9646fDAD…</code>). Paymaster: Circle Paymaster
              (<code>0x0578cFB2…</code>). Sardis ships no custom money-handling contract if an audited one
              fits — zero audit surface at MVP.
            </div>
          </div>
          <div class="card">
            <div class="card-title">On-chain for evidence, off-chain for decisions</div>
            <div class="card-description">
              Policy decisions live in Postgres (migration 041) because policies change. What goes on-chain
              is the <em>Merkle root</em> of a batch of those decisions (<code>SardisLedgerAnchor</code>) —
              tamper-evidence without tying policy logic to chain latency or upgrade ceremony.
            </div>
          </div>
          <div class="card">
            <div class="card-title">Standards-compliant identity &amp; reputation</div>
            <div class="card-description">
              Agent identity is ERC-8004 (ERC-721 token + reputation + validation registries). A wallet can
              prove "I am agent #42 in this registry" without trusting a Sardis API. Reputation is
              submitted by clients, signed on-chain, and queryable by any counterparty.
            </div>
          </div>
          <div class="card">
            <div class="card-title">ERC-8183 for commerce, not custom escrows</div>
            <div class="card-description">
              Escrow-based agent commerce follows the ERC-8183 spec with a strict state machine and
              selector-based hooks (<code>IACPHook</code>). Easier for counterparties to integrate than a
              Sardis-only escrow; easier to audit.
            </div>
          </div>
          <div class="card">
            <div class="card-title">Hook-dispatch over inheritance</div>
            <div class="card-description">
              <code>SardisJobManager</code> routes hook calls through <code>IACPHook</code> with a gas
              limit — before-hooks can block, after-hooks are fire-and-forget. Keeps hook failures from
              griefing the core flow while still letting composability extensions run.
            </div>
          </div>
          <div class="card">
            <div class="card-title">Apache 2.0 for RefundProtocol</div>
            <div class="card-description">
              <code>RefundProtocol.sol</code> is Circle's audited implementation, vendored in-tree under
              Apache 2.0 — not a rewrite. The point is to reuse the audit, not re-audit.
            </div>
          </div>
        </div>
      </section>

      <!-- Contracts -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">The Catalogue</div>
          <h2>Every contract, file by file.</h2>
          <p class="text-muted" style="max-width:720px;">
            Source: <code>contracts/src/</code>. Purpose statements are quoted or paraphrased from each
            file's NatSpec.
          </p>
        </div>

        <!-- SardisLedgerAnchor -->
        <div class="contract-block">
          <div class="cb-head">
            <div>
              <div class="cb-name">SardisLedgerAnchor.sol</div>
              <div class="text-xs text-muted text-mono">contracts/src/SardisLedgerAnchor.sol · Solidity ^0.8.20</div>
            </div>
            <div class="cb-tags">
              <span class="cb-tag">MIT</span>
              <span class="cb-tag">Production</span>
              <span class="cb-tag">Ownable</span>
            </div>
          </div>
          <div class="cb-body">
            <div class="cb-purpose">
              Stores Merkle roots of audit-log batches for tamper evidence. Minimal by design — the
              ledger itself stays off-chain in Postgres; only the root crosses the chain boundary.
              <code>anchor(root, anchorId)</code> writes once, never twice; <code>verify(root)</code>
              returns the timestamp (0 if never anchored). This is the contract that makes "trust our
              logs" obsolete.
            </div>
            <dl class="defs">
              <dt>Key API</dt><dd><code>anchor(bytes32 root, string anchorId)</code> · <code>verify(bytes32) → uint256 timestamp</code></dd>
              <dt>Event</dt><dd><code>Anchored(bytes32 indexed root, string anchorId, uint256 timestamp)</code></dd>
              <dt>Upstream</dt><dd><code>sardis-ledger</code> batches → on-chain call from ops service.</dd>
            </dl>
          </div>
        </div>

        <!-- SardisIdentityRegistry -->
        <div class="contract-block">
          <div class="cb-head">
            <div>
              <div class="cb-name">SardisIdentityRegistry.sol</div>
              <div class="text-xs text-muted text-mono">Solidity ^0.8.24 · implements ERC-8004 Identity</div>
            </div>
            <div class="cb-tags">
              <span class="cb-tag">MIT</span>
              <span class="cb-tag">ERC-8004</span>
              <span class="cb-tag">ERC-721</span>
              <span class="cb-tag">EIP-712</span>
              <span class="cb-tag">ERC-1271</span>
            </div>
          </div>
          <div class="cb-body">
            <div class="cb-purpose">
              ERC-8004 Identity Registry — on-chain agent identity as an ERC-721 token. Global addressing:
              <code>eip155:&#123;chainId&#125;:&#123;registryAddress&#125;#&#123;agentId&#125;</code>. Three <code>register()</code>
              overloads (URI + metadata, URI only, bare). Agent-wallet linking verified via EIP-712
              signature (EOA) or ERC-1271 (smart contract). Wallet is cleared on token transfer so the new
              owner has to re-verify.
            </div>
            <dl class="defs">
              <dt>Key API</dt><dd><code>register(...)</code> · <code>setAgentWallet(agentId, wallet, deadline, sig)</code> · <code>setMetadata(agentId, key, value)</code></dd>
              <dt>Invariant</dt><dd>Reserved key <code>agentWallet</code> cannot be written via <code>setMetadata</code> — only via signed flow.</dd>
              <dt>Spec</dt><dd><a href="https://eips.ethereum.org/EIPS/eip-8004" target="_blank" rel="noopener">eips.ethereum.org/EIPS/eip-8004</a></dd>
            </dl>
          </div>
        </div>

        <!-- SardisReputationRegistry -->
        <div class="contract-block">
          <div class="cb-head">
            <div>
              <div class="cb-name">SardisReputationRegistry.sol</div>
              <div class="text-xs text-muted text-mono">Solidity ^0.8.24 · implements ERC-8004 Reputation</div>
            </div>
            <div class="cb-tags">
              <span class="cb-tag">MIT</span>
              <span class="cb-tag">ERC-8004</span>
            </div>
          </div>
          <div class="cb-body">
            <div class="cb-purpose">
              Client-submitted on-chain feedback for agents. Each feedback is <code>int128 value</code> +
              decimals + tags + endpoint + off-chain URI + hash. Revocation is soft (marked, never
              deleted). Agent owners (or approved operators) can submit response records pointing at
              their side of the story.
            </div>
            <dl class="defs">
              <dt>Rules</dt><dd>Submitter MUST NOT be the agent owner; valueDecimals in [0, 18]; only original submitter can revoke.</dd>
              <dt>Linked to</dt><dd><code>SardisIdentityRegistry</code> (ERC-721) — feedback keyed by <code>agentId</code>.</dd>
            </dl>
          </div>
        </div>

        <!-- SardisValidationRegistry -->
        <div class="contract-block">
          <div class="cb-head">
            <div>
              <div class="cb-name">SardisValidationRegistry.sol</div>
              <div class="text-xs text-muted text-mono">Solidity ^0.8.24 · implements ERC-8004 Validation</div>
            </div>
            <div class="cb-tags">
              <span class="cb-tag">MIT</span>
              <span class="cb-tag">ERC-8004</span>
            </div>
          </div>
          <div class="cb-body">
            <div class="cb-purpose">
              Agent owners request validation from a designated validator; the validator responds with a
              score (0–100). Records are queryable by <code>requestHash</code>. Validators can respond
              multiple times to update the score.
            </div>
            <dl class="defs">
              <dt>Record shape</dt><dd><code>validatorAddress</code> · <code>agentId</code> · <code>response (uint8)</code> · <code>responseHash</code> · <code>tag</code> · <code>lastUpdate</code>.</dd>
              <dt>Immutable</dt><dd><code>identityRegistry</code> address is set at construction.</dd>
            </dl>
          </div>
        </div>

        <!-- SardisJobManager -->
        <div class="contract-block">
          <div class="cb-head">
            <div>
              <div class="cb-name">SardisJobManager.sol</div>
              <div class="text-xs text-muted text-mono">Solidity ^0.8.24 · implements ERC-8183</div>
            </div>
            <div class="cb-tags">
              <span class="cb-tag">MIT</span>
              <span class="cb-tag">ERC-8183</span>
              <span class="cb-tag">Escrow</span>
              <span class="cb-tag">ReentrancyGuard</span>
              <span class="cb-tag">Pausable</span>
            </div>
          </div>
          <div class="cb-body">
            <div class="cb-purpose">
              Escrow-based job primitive for agentic commerce. Full ERC-8183 state machine:
              <code>Open → Funded → Submitted → Completed/Rejected/Expired</code> with
              <code>claimRefund</code> on expiry. Hook dispatch through <code>IACPHook</code> — a
              <strong>before</strong> hook called with <code>HOOK_GAS_LIMIT</code> whose revert blocks the
              action, and a fire-and-forget <strong>after</strong> hook whose revert is ignored. Bounded
              gas prevents hook-griefing.
            </div>
            <dl class="defs">
              <dt>State machine</dt><dd>Open → Funded (fund) · Open → Rejected (reject) · Funded → Submitted (submit) · Submitted → Completed (complete) · Submitted → Rejected (reject) · Funded/Submitted → Expired (claimRefund).</dd>
              <dt>Caps (MVP)</dt><dd>1% fee cap, USDC-only, trust hooks disabled post-launch — relaxable post-audit.</dd>
              <dt>Spec</dt><dd><a href="https://eips.ethereum.org/EIPS/eip-8183" target="_blank" rel="noopener">eips.ethereum.org/EIPS/eip-8183</a></dd>
            </dl>
          </div>
        </div>

        <!-- SardisJobRegistry -->
        <div class="contract-block">
          <div class="cb-head">
            <div>
              <div class="cb-name">SardisJobRegistry.sol</div>
              <div class="text-xs text-muted text-mono">Solidity ^0.8.24</div>
            </div>
            <div class="cb-tags">
              <span class="cb-tag">MIT</span>
              <span class="cb-tag">Reputation</span>
              <span class="cb-tag">Ownable</span>
            </div>
          </div>
          <div class="cb-body">
            <div class="cb-purpose">
              On-chain reputation store for ERC-8183 agents. Tracks completed / rejected jobs, earnings,
              spending per agent. Only authorized writers (the Job Manager, trusted hooks) can update
              records. Trust score is computed on-chain in basis points (0–10000):
              <code>baseScore = completed / (completed + rejected) × 10000</code> + up to a 10% volume
              bonus capped at 10000.
            </div>
            <dl class="defs">
              <dt>Auth model</dt><dd><code>authorizedWriters</code> mapping — only owner can toggle.</dd>
              <dt>Companion of</dt><dd><code>SardisJobManager</code> — Manager calls into Registry on every complete/reject.</dd>
            </dl>
          </div>
        </div>

        <!-- RefundProtocol -->
        <div class="contract-block">
          <div class="cb-head">
            <div>
              <div class="cb-name">RefundProtocol.sol</div>
              <div class="text-xs text-muted text-mono">Solidity ^0.8.24 · Circle, vendored</div>
            </div>
            <div class="cb-tags">
              <span class="cb-tag">Apache 2.0</span>
              <span class="cb-tag">Circle (audited)</span>
              <span class="cb-tag">EIP-712</span>
            </div>
          </div>
          <div class="cb-body">
            <div class="cb-purpose">
              Circle's <code>RefundProtocol</code>, vendored in-tree. Time-locked payments (up to 180
              days) with arbiter-enabled early withdrawal authorised by EIP-712 signed
              <code>EarlyWithdrawalByArbiter</code> messages. Sardis uses it for dispute-resolved refunds
              so neither buyer nor merchant has to trust Sardis custody.
            </div>
            <dl class="defs">
              <dt>Payment struct</dt><dd><code>to · amount · releaseTimestamp · refundTo · withdrawnAmount · refunded</code>.</dd>
              <dt>Max lockup</dt><dd>180 days (<code>MAX_LOCKUP_SECONDS</code>).</dd>
              <dt>Why in-tree</dt><dd>Pin version under Sardis build/audit; swap upstream fixes with explicit review.</dd>
            </dl>
          </div>
        </div>

        <!-- SardisPolicyModule (DEPRECATED) -->
        <div class="contract-block">
          <div class="cb-head">
            <div>
              <div class="cb-name">SardisPolicyModule.sol</div>
              <div class="text-xs text-muted text-mono">Solidity ^0.8.20 · Safe module (reference only)</div>
            </div>
            <div class="cb-tags">
              <span class="cb-tag warn">Deprecated</span>
              <span class="cb-tag">MIT</span>
              <span class="cb-tag">Safe module</span>
            </div>
          </div>
          <div class="cb-body">
            <div class="cb-purpose">
              Safe module that enforces spending policies for AI agent wallets — per-tx + daily limits,
              co-sign mode (10× limit when co-signed by Sardis), merchant allow/deny lists, token
              allowlist, pause/unpause.
              <strong>Superseded</strong> by the pre-deployed, audited Zodiac Roles module at
              <code>0x9646fDAD06d3e24444381f44362a3B0eB343D337</code>. Kept for reference; not deployed to
              mainnet for MVP (no custom audit dependency).
            </div>
            <dl class="defs">
              <dt>Status</dt><dd>Do-not-deploy. Any agent-wallet policy enforcement routes through Zodiac Roles.</dd>
            </dl>
          </div>
        </div>

        <!-- SardisVerifyingPaymaster (DEPRECATED) -->
        <div class="contract-block">
          <div class="cb-head">
            <div>
              <div class="cb-name">SardisVerifyingPaymaster.sol</div>
              <div class="text-xs text-muted text-mono">Solidity ^0.8.20 · ERC-4337 paymaster (reference only)</div>
            </div>
            <div class="cb-tags">
              <span class="cb-tag warn">Deprecated</span>
              <span class="cb-tag">MIT</span>
              <span class="cb-tag">ERC-4337</span>
            </div>
          </div>
          <div class="cb-body">
            <div class="cb-purpose">
              ERC-4337 verifying paymaster with wallet allowlist, per-op cap, and daily sponsor cap.
              Validation optionally consumes off-chain verifier signatures in <code>paymasterData</code>.
              <strong>Superseded</strong> by Circle Paymaster
              (<code>0x0578cFB241215b77442a541325d6A4E6dFE700Ec</code>, permissionless, USDC gas). Kept
              for reference; not deployed.
            </div>
            <dl class="defs">
              <dt>Today</dt><dd>Primary: Circle Paymaster. Backup: Pimlico (sponsor model).</dd>
            </dl>
          </div>
        </div>
      </section>

      <!-- Supporting directories -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Supporting dirs</div>
          <h2>Hooks, interfaces, verifiers.</h2>
        </div>
        <table class="data">
          <thead>
            <tr><th>Path</th><th>Role</th></tr>
          </thead>
          <tbody>
            <tr><td><code>src/hooks/SardisReputationHook.sol</code></td><td>IACPHook impl that writes into <code>SardisJobRegistry</code> on complete/reject — keeps reputation accounting in-contract.</td></tr>
            <tr><td><code>src/hooks/SardisTrustHook.sol</code></td><td>IACPHook impl gating ERC-8183 actions on a trust-score threshold from the reputation registry.</td></tr>
            <tr><td><code>src/interfaces/IACPHook.sol</code></td><td>Selector-based hook dispatch interface — beforeAction, afterAction.</td></tr>
            <tr><td><code>src/interfaces/IIdentityRegistry.sol</code></td><td>ERC-8004 Identity Registry interface.</td></tr>
            <tr><td><code>src/interfaces/IReputationRegistry.sol</code></td><td>ERC-8004 Reputation Registry interface.</td></tr>
            <tr><td><code>src/interfaces/IValidationRegistry.sol</code></td><td>ERC-8004 Validation Registry interface.</td></tr>
            <tr><td><code>src/interfaces/IJob.sol</code></td><td>ERC-8183 job interface — events, errors, state enum.</td></tr>
            <tr><td><code>src/interfaces/IJobRegistry.sol</code></td><td>Reputation-writer interface for job outcomes.</td></tr>
            <tr><td><code>src/verifiers/FundingSufficiencyVerifier.sol</code></td><td>ZK-proof verifier: "agent wallet has at least X without revealing balance."</td></tr>
            <tr><td><code>src/verifiers/IdentityProofVerifier.sol</code></td><td>ZK-proof verifier for identity attestation without doxxing the agent.</td></tr>
            <tr><td><code>src/verifiers/MandateComplianceVerifier.sol</code></td><td>ZK-proof verifier proving a transaction complies with a mandate without leaking the mandate body.</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Interaction diagram -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Interaction</div>
          <h2>How the contracts compose.</h2>
          <p class="text-muted" style="max-width:720px;">
            A job lifecycle touches identity, reputation, the job manager, and — when off-chain evidence
            needs to be proven later — the ledger anchor.
          </p>
        </div>
        <div class="diagram">
          <pre class="mermaid" is:raw>
flowchart LR
    subgraph Identity[ERC-8004 Identity]
      IR[SardisIdentityRegistry<br/>ERC-721 agent token]
      RR[SardisReputationRegistry<br/>client feedback]
      VR[SardisValidationRegistry<br/>validator scores]
    end
    subgraph Commerce[ERC-8183 Commerce]
      JM[SardisJobManager<br/>escrow + state machine]
      JR[SardisJobRegistry<br/>on-chain reputation]
      HK[Hooks<br/>Reputation · Trust]
    end
    subgraph Refund[Dispute]
      RP[RefundProtocol<br/>Circle, Apache 2.0]
    end
    subgraph Evidence[Audit]
      LA[SardisLedgerAnchor<br/>Merkle roots]
    end
    IR --> RR
    IR --> VR
    IR -. agent id .-> JM
    JM --> HK
    HK --> JR
    JM -. dispute .-> RP
    OFF[sardis-ledger<br/>off-chain batches] --> LA
          </pre>
        </div>
      </section>

      <!-- Build / test -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Build &amp; test</div>
          <h2>Toolchain.</h2>
        </div>
        <table class="data">
          <thead>
            <tr><th>What</th><th>Command</th><th>Notes</th></tr>
          </thead>
          <tbody>
            <tr><td>Compile</td><td><code>cd contracts &amp;&amp; forge build</code></td><td>Foundry; Solidity 0.8.20–0.8.24.</td></tr>
            <tr><td>Test</td><td><code>cd contracts &amp;&amp; forge test</code></td><td>Fuzz + invariant tests for Job state machine + anchor.</td></tr>
            <tr><td>Deps</td><td><code>lib/forge-std</code> · <code>lib/openzeppelin-contracts</code></td><td>Both vendored as git submodules under <code>contracts/lib/</code>.</td></tr>
            <tr><td>Deploy script</td><td><code>scripts/deploy-contracts.sh</code></td><td>Public contract deployment helper with dry-run defaults and explicit broadcast confirmation for mainnet.</td></tr>
            <tr><td>Deploy target</td><td>Base mainnet (primary), Tempo mainnet</td><td>Needs deployer wallet with ~$2–5 ETH on Base, Alchemy API key, BaseScan API key.</td></tr>
          </tbody>
        </table>
      </section>

      <!-- External contracts Sardis depends on -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">External</div>
          <h2>Audited contracts we rely on but don't deploy.</h2>
        </div>
        <table class="data">
          <thead>
            <tr><th>Contract</th><th>Address</th><th>Why we don't own it</th></tr>
          </thead>
          <tbody>
