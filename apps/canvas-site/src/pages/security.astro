---
import Canvas from "../layouts/Canvas.astro";
---

<Canvas title="19 · Security Model — Sardis Canvas" currentId="security">

<section class="hero">
        <span class="eyebrow">Canvas 19 · Ops</span>
        <h1>Security Model</h1>
        <p class="hero-lead">
          Sardis handles money on behalf of AI agents that can be prompt-injected, API keys that can leak,
          and merchants that may be malicious. The security model is a chain of small, auditable decisions
          — every one of them fail-closed — anchored by an append-only ledger so nobody, including us, can
          quietly edit history.
        </p>
      </section>

      <section class="section" style="padding-top:0; border-top:0;">
        <div class="callout callout-info">
          <span class="callout-title">TL;DR</span>
          No private keys in Sardis memory. No silent fallbacks. Every payment traverses the
          <code>PreExecutionPipeline</code> before a signature is requested. Every decision is written
          to <code>policy_decisions</code> and anchored on-chain. One kill switch freezes every wallet in
          under a second.
        </div>
      </section>

      <!-- Trust boundaries -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Trust Boundaries</div>
          <h2>Who trusts whom, and for what.</h2>
          <p class="text-muted" style="max-width:720px;">
            A trust boundary is where a request crosses from a less-trusted to a more-trusted context —
            or vice versa. Every boundary is also an audit point. This is the actual topology, not an
            aspirational one.
          </p>
        </div>
        <div class="diagram">
          <pre class="mermaid" is:raw>
flowchart TB
    subgraph Untrusted[Untrusted zone]
      Agent[AI Agent · LangChain / CrewAI / custom]
      Merchant[Merchant checkout embed]
      Public[Public internet]
    end

    subgraph Boundary1[Boundary 1 · API gateway]
      ApiKey[API key + HMAC / JWT]
      TAP[TAP verification]
      CORS[CORS · CSP · HSTS]
      RateLimit[Rate limiter · Redis]
    end

    subgraph SemiTrusted[Semi-trusted · Sardis core]
      Orchestrator[PaymentOrchestrator]
      Pipeline[PreExecutionPipeline]
      Ledger[Ledger + policy_decisions]
    end

    subgraph Boundary2[Boundary 2 · MPC + chain]
      Turnkey[Turnkey · sub-org per tenant]
      Alchemy[Alchemy RPC]
      Chain[Base / Tempo mainnet]
    end

    subgraph Boundary3[Boundary 3 · Compliance providers]
      Didit[Didit KYC]
      Elliptic[Elliptic AML]
      Stripe[Stripe Connect / Issuing]
    end

    Agent --> ApiKey
    Merchant --> CORS
    Public --> TAP
    ApiKey --> RateLimit
    CORS --> RateLimit
    TAP --> RateLimit
    RateLimit --> Orchestrator
    Orchestrator --> Pipeline
    Pipeline --> Ledger
    Pipeline --> Didit
    Pipeline --> Elliptic
    Orchestrator --> Turnkey
    Turnkey --> Alchemy
    Alchemy --> Chain
    Orchestrator --> Stripe
          </pre>
        </div>
      </section>

      <!-- Boundary details -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Boundary detail</div>
          <h2>What each boundary asserts.</h2>
        </div>
        <table class="data">
          <thead>
            <tr><th>Boundary</th><th>Direction</th><th>Enforced by</th><th>Failure mode</th></tr>
          </thead>
          <tbody>
            <tr><td>Agent → API</td><td>untrusted → semi</td><td>API key hashed SHA-256 at rest, CORS, rate limit, request-body size limit (<code>RequestBodyLimitMiddleware</code>)</td><td>Deny, log with request ID</td></tr>
            <tr><td>Protocol payload → API</td><td>untrusted → semi</td><td>TAP verification middleware (JWKS, 1h TTL, 4h max-stale before reject)</td><td>Reject when JWKS unreachable beyond max-stale</td></tr>
            <tr><td>API → Orchestrator</td><td>semi → semi</td><td><code>require_principal</code> dependency, <code>PaymentOrchestrator.execute()</code> as single chokepoint</td><td>No chain_executor bypass — DI lockdown (Phase 2)</td></tr>
            <tr><td>Orchestrator → MPC</td><td>semi → provider</td><td>Turnkey sub-org per tenant, ECDSA-signed API requests</td><td>Signature request denied by Turnkey policy</td></tr>
            <tr><td>Orchestrator → Compliance</td><td>semi → provider</td><td>Didit KYC, Elliptic AML</td><td>Unreachable provider → deny (fail-closed)</td></tr>
            <tr><td>Ledger → Chain</td><td>internal → public</td><td><code>SardisLedgerAnchor.sol</code> Merkle root</td><td>Batch must settle on-chain before evidence export is authoritative</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Threat model -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Threat model</div>
          <h2>Who breaks in, and what stops them.</h2>
          <p class="text-muted" style="max-width:720px;">
            Each row is an actor we actively design against. The "mitigations" column is code that
            already exists — not a wishlist.
          </p>
        </div>
        <table class="data">
          <thead>
            <tr><th>Actor</th><th>Attack</th><th>Mitigations</th><th>Residual risk</th></tr>
          </thead>
          <tbody>
            <tr>
              <td>Compromised agent</td>
              <td>Prompt injection tricks the agent into calling <code>pay()</code> with a hostile recipient / amount.</td>
              <td>Non-custodial (no keys to steal), spending policy caps per-txn and per-window, AGIT fail-closed, anomaly scorer (<code>anomaly_detection.py</code>), human approval for risky actions (<code>approval_service.py</code>).</td>
              <td>Agent can drain up to policy cap. Mitigation: tight caps + approval thresholds.</td>
            </tr>
            <tr>
              <td>Compromised API key</td>
              <td>Key leaks via logs, model output, or client-side reverse-engineer.</td>
              <td>Keys hashed SHA-256 at rest, rate limiter fail-closed if Redis unreachable, anomaly detector flags new-geo usage, kill switch freezes wallets in one call.</td>
              <td>Small window before anomaly fires. Mitigation: customer rotation workflow + audit alerts.</td>
            </tr>
            <tr>
              <td>Compromised MPC provider</td>
              <td>Attacker gains Turnkey org-level access.</td>
              <td>Sub-org per tenant — blast radius capped at one customer. Turnkey policy engine enforces the same spending rules server-side.</td>
              <td>Catastrophic if root org compromised. Mitigation: provider abstraction lets us add Fireblocks/Circle/Lit as a second root.</td>
            </tr>
            <tr>
              <td>Malicious merchant</td>
              <td>Merchant fakes agent signals to claim funds, or sets up checkout to phish users.</td>
              <td>Merchant trust scoring, capability gating, embed-origin CORS restriction (<code>embed_origin</code> column, migration 031), session <code>client_secret</code> + <code>idempotency_key</code> unique constraint, <code>SELECT … FOR UPDATE NOWAIT</code> on settlement.</td>
              <td>Policy-level abuse (false advertising etc.). Mitigation: legal review + offboarding pipeline.</td>
            </tr>
            <tr>
              <td>Insider (Sardis employee)</td>
              <td>Staff modifies a ledger entry to hide a bad decision.</td>
              <td>Append-only <code>ledger_entries</code>, <code>policy_decisions</code> writes per request, Merkle-anchored batches via <code>SardisLedgerAnchor.sol</code>, evidence export signed by chain state.</td>
              <td>A re-anchor could theoretically rewrite recent history if insider controls the deployer key — but divergence is visible on-chain.</td>
            </tr>
            <tr>
              <td>Replay / forgery</td>
              <td>Attacker re-submits a valid mandate to execute again.</td>
              <td>Postgres + Redis replay cache (<code>MandateArchive</code> + <code>dedup_store.py</code>), nonce enforcement, DB-level <code>idempotency_key</code> unique constraint (migration 031), mandate TTLs.</td>
              <td>Low — doubled on two independent stores.</td>
            </tr>
            <tr>
              <td>Provider outage</td>
              <td>Didit / Elliptic / Turnkey down — tempts "just approve for now."</td>
              <td>Every pipeline step defaults to deny on timeout or error. No "allow on failure" path in prod.</td>
              <td>Availability hit — accepted trade-off against silent compromise.</td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- Fail-closed matrix -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Fail-closed</div>
          <h2>What each layer does when something goes wrong.</h2>
          <p class="text-muted" style="max-width:720px;">
            The override flag <code>SARDIS_AGIT_FAIL_OPEN=true</code> exists for local dev only. Default
            for <code>agit_fail_open</code> in <code>config.py</code> is <code>False</code>. Production
            must deny.
          </p>
        </div>
        <table class="data">
          <thead>
            <tr><th>Layer</th><th>Control</th><th>On normal path</th><th>On failure</th></tr>
          </thead>
          <tbody>
            <tr><td>API gateway</td><td>Rate limiter (Redis)</td><td>Allow under threshold</td><td>Redis unreachable → deny. No in-memory fallback in prod.</td></tr>
            <tr><td>API gateway</td><td>TAP JWKS fetch</td><td>Verify signature</td><td>JWKS fetch fails, stale cache &gt; <code>SARDIS_TAP_JWKS_MAX_STALE_SECONDS</code> → reject.</td></tr>
            <tr><td>PreExecutionPipeline</td><td>Spending policy</td><td>Evaluate against natural-language rule</td><td>Evaluator raises → deny + ledger entry with reason.</td></tr>
            <tr><td>PreExecutionPipeline</td><td>AGIT (Agent Identity and Trust)</td><td>Chain-of-trust lookup</td><td>Unreachable → <code>settings.agit_fail_open=False</code> rejects. <code>control_plane.py</code> line 210.</td></tr>
            <tr><td>PreExecutionPipeline</td><td>KYA / FIDES</td><td>Score agent + counterparty</td><td>Provider error → deny.</td></tr>
            <tr><td>PreExecutionPipeline</td><td>MCC classifier</td><td>Map merchant category</td><td>Unknown MCC → deny (<code>mcc_service.py</code> line 103).</td></tr>
            <tr><td>Compliance</td><td>AML / sanctions screening</td><td>Green → proceed</td><td>No sanctions service → deny deposit (<code>inbound_payment_service.py</code>). Any raised exception → deny.</td></tr>
            <tr><td>Orchestrator</td><td>ExecutionMode</td><td>Honour explicit mode</td><td>Viability check fails → <code>FAIL_CLOSED</code>, no silent fallback (<code>execution_mode.py</code>).</td></tr>
            <tr><td>State machines</td><td>A2A escrow</td><td>Only whitelisted transitions</td><td>Invalid transition → refuse (<code>a2a_escrow.py</code>).</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Secrets + headers -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Secrets + transport</div>
          <h2>Secrets management and header posture.</h2>
        </div>
        <div class="grid grid-2">
          <div class="card">
            <div class="card-title">Secrets never in code</div>
            <div class="card-description">
              All provider credentials live in env vars loaded from Google Secret Manager or Vercel env.
              <code>gitleaks</code> runs on every PR with full history (<code>secret-scan.yml</code>,
              <code>fetch-depth: 0</code>). A matched leak fails the run — no merge.
              API keys are stored in Postgres as SHA-256 hashes, not plaintext.
            </div>
          </div>
          <div class="card">
            <div class="card-title">Middleware stack (sardis-api)</div>
            <div class="card-description">
              Order from <code>packages/reference-api/sardis_server/main.py</code>: RequestId →
              StructuredLogging → SecurityHeaders (CSP/HSTS) → RequestBodyLimit (10MB default, 1MB
              webhooks, 512KB checkout, 64KB policies) → RateLimit → TAP → x402 → UsageMetering →
              ActivityLogger → CORS (no wildcards — <code>settings.allowed_origins_list</code>) →
              routers. Every step is fail-closed.
            </div>
          </div>
          <div class="card">
            <div class="card-title">Webhook signatures</div>
            <div class="card-description">
              Required in all non-dev environments. HMAC via <code>X-Sardis-Signature</code> and
              <code>X-Sardis-Timestamp</code>. Delivery uses the transactional outbox pattern —
              <code>webhook_outbox</code> (migration 032) is written in the same transaction as the
              business operation and flushed by a background worker. <code>event_id</code> keyed dedup.
            </div>
          </div>
          <div class="card">
            <div class="card-title">Replay + idempotency</div>
            <div class="card-description">
              Redis + Postgres replay caches for mandates (Phase 3 durable state).
              <code>idempotency_key</code> DB-level unique constraint on checkout sessions
              (migration 031). <code>SELECT … FOR UPDATE NOWAIT</code> prevents double-pay race at
              settlement.
            </div>
          </div>
        </div>
      </section>

      <!-- TDD remediation -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Hardening history</div>
          <h2>TDD remediation — three phases, March 2026.</h2>
          <p class="text-muted" style="max-width:720px;">
            The security posture above is the result of a deliberate three-phase hardening done in
            March 2026. Each phase was merged incrementally with tests. Design doc:
            <code>docs/plans/2026-03-09-tdd-remediation-90-day-design.md</code>.
          </p>
        </div>
        <table class="data">
          <thead>
            <tr><th>Phase</th><th>Focus</th><th>What shipped</th></tr>
          </thead>
          <tbody>
            <tr>
              <td>Phase 1</td>
              <td>Security + correctness</td>
              <td>OAuth CSRF fix, admin fail-closed defaults, webhook signatures required in prod, gitleaks in CI, group-policy TTL + budget decrement, queue interface fix, AGIT default fail-closed.</td>
            </tr>
            <tr>
              <td>Phase 2</td>
              <td>Single execution path</td>
              <td><code>PreExecutionPipeline</code> built; AGIT/KYA/FIDES hooks; router migrations (wallets, mandates, ap2) onto <code>PaymentOrchestrator</code>; DI lockdown (<code>chain_executor</code> private); unified <code>PaymentResult</code>.</td>
            </tr>
            <tr>
              <td>Phase 3</td>
              <td>Durable state + moat</td>
              <td>Redis dedup store, Postgres reconciliation queue, Redis replay cache, rate limiter enforcement, attestation envelope endpoint, README maturity tiers.</td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- Kill switch -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Incident response</div>
          <h2>Kill switch.</h2>
          <p class="text-muted" style="max-width:720px;">
            If we see a confirmed compromise, one privileged call freezes every wallet. The action is
            itself audited — see migration <code>064_emergency_freeze.sql</code>.
          </p>
        </div>
        <div class="grid grid-2">
          <div class="card">
            <div class="card-title">What gets frozen</div>
            <div class="card-description">
              All MPC signing requests denied at the orchestrator boundary, in-flight batches cancelled
              before broadcast, background reconciliation suspended. Chain-side funds aren't moved —
              they simply stop being signable from Sardis. Non-custodial works in our favour here.
            </div>
          </div>
          <div class="card">
            <div class="card-title">Audit record</div>
            <div class="card-description">
              <code>emergency_freeze_events</code>: <code>action</code> (<code>freeze_all</code> /
              <code>unfreeze_all</code>), <code>triggered_by</code>, <code>wallets_affected</code>,
              <code>reason</code>, <code>notes</code>, <code>created_at</code>. Indexed descending on
              <code>created_at</code> so the operator dashboard can always show the latest action first.
            </div>
          </div>
        </div>
      </section>

      <!-- Evidence -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Audit evidence</div>
          <h2>Every decision, exportable.</h2>
        </div>
        <table class="data">
          <thead>
            <tr><th>Layer</th><th>Table / file</th><th>Evidence value</th></tr>
          </thead>
          <tbody>
            <tr><td>Every allow/deny</td><td><code>policy_decisions</code></td><td>Reason code + rule snapshot at decision time. Regulators can see why a transaction was allowed, not just that it was.</td></tr>
            <tr><td>Every money movement</td><td><code>ledger_entries</code></td><td>Append-only. Every row carries the pre-execution decision ID.</td></tr>
            <tr><td>On-chain proof</td><td><code>SardisLedgerAnchor.sol</code></td><td>Merkle-root batches anchored on Base. Once anchored, re-ordering is detectable.</td></tr>
            <tr><td>Regulator package</td><td><code>evidence_export</code> router</td><td>Produces a signed bundle: policy_decisions + ledger rows + Merkle proof + chain tx hash.</td></tr>
            <tr><td>Incident response</td><td><code>emergency_freeze_events</code> (migration 064)</td><td>Every freeze/unfreeze with actor and reason.</td></tr>
            <tr><td>Webhook delivery</td><td><code>webhook_outbox</code> (migration 032)</td><td>Proof of at-least-once delivery with attempts + timestamps.</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Cross-refs -->
      <section class="section">
        <div class="section-header">
          <div class="eyebrow">Go deeper</div>
          <h2>Related canvases.</h2>
        </div>
        <div class="grid grid-2">
          <a class="canvas-card" href="/architecture">
            <div class="canvas-card-num">01 · System</div>
            <div class="canvas-card-title">Architecture Overview</div>
            <div class="canvas-card-desc">Where these boundaries sit in the seven-layer stack.</div>
          </a>
          <a class="canvas-card" href="/cicd">
            <div class="canvas-card-num">18 · Ops</div>
            <div class="canvas-card-title">CI / CD</div>
            <div class="canvas-card-desc">How CodeQL, gitleaks, Trivy, Bandit, fuzz, and Scorecard enforce this model before merge.</div>
          </a>
          <a class="canvas-card" href="/policy-engine">
            <div class="canvas-card-num">08 · Flows</div>
            <div class="canvas-card-title">Policy Engine</div>
            <div class="canvas-card-desc">How natural-language rules become the deny decisions above.</div>
          </a>
          <a class="canvas-card" href="/payment-flow">
            <div class="canvas-card-num">07 · Flows</div>
            <div class="canvas-card-title">Payment Flow</div>
            <div class="canvas-card-desc">The request's journey through every boundary, end to end.</div>
          </a>
        </div>
      </section>
</Canvas>
