---
import Canvas from "../layouts/Canvas.astro";

const recommended = [
  { slug: "architecture",      num: "01", title: "Architecture Overview",   desc: "Seven-layer stack — the whole spine in one page. Start here." },
  { slug: "protocol-objects",  num: "20", title: "Protocol Objects (10)",   desc: "Agent Certificate through Mandate Tree — every signed artifact." },
  { slug: "state-machine",     num: "21", title: "22-State Machine",         desc: "The full payment lifecycle. Card networks do 2 states; we do 22." },
  { slug: "dual-rail",         num: "22", title: "Dual-Rail Architecture",   desc: "Internal ledger as primary rail. External rails are on/off ramps." },
  { slug: "sardis-connect",    num: "24", title: "Sardis Connect",           desc: "Three-line merchant SDK — agent pays stablecoin, merchant receives USD." },
];
---

<Canvas title="Sardis — Canvases" currentId="index">
  <Fragment slot="head">
    <style is:global set:html={`
      .ai-bar { display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 20px 24px; border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--card); }
      .ai-bar-text { font-size: 14px; color: var(--text-secondary); line-height: 1.5; }
      .ai-bar-text strong { color: var(--text-primary); }
      .ai-actions { display: flex; gap: 8px; flex-wrap: wrap; }
      .ai-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 14px; border-radius: 8px; border: 1px solid var(--border); background: var(--card); color: var(--text-primary); font-size: 13px; font-weight: 500; cursor: pointer; transition: background 150ms ease, border-color 150ms ease, transform 150ms ease; text-decoration: none; }
      .ai-btn:hover { background: var(--muted); border-color: var(--border-strong); opacity: 1; }
      .ai-btn:active { transform: scale(0.97); }
      .ai-btn svg { width: 16px; height: 16px; }
      .ai-btn-primary { background: var(--primary); color: var(--primary-fg); border-color: var(--primary); }
      .ai-btn-primary:hover { background: var(--primary); opacity: 0.85; }
      .ai-btn[data-state="copied"] { background: var(--success-muted); color: var(--success); border-color: var(--success); }

      .rec-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; }
      .rec-card { display: block; padding: 18px 20px; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--card); text-decoration: none; color: var(--text-primary); transition: border-color 200ms ease, transform 200ms ease; }
      .rec-card:hover { border-color: var(--border-strong); transform: translateY(-1px); opacity: 1; }
      .rec-card .rec-num { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
      .rec-star { color: var(--warning); font-size: 11px; }
      .rec-card .rec-title { font-size: 14.5px; font-weight: 600; margin-bottom: 4px; }
      .rec-card .rec-desc { font-size: 12.5px; color: var(--text-muted); line-height: 1.5; }

      @media (max-width: 700px) {
        .ai-bar { grid-template-columns: 1fr; }
        .ai-actions { justify-content: flex-start; }
      }

      .manifesto-pointer {
        display: grid;
        grid-template-columns: auto 1fr auto;
        grid-template-areas: "label title arrow" "label hint arrow";
        align-items: center;
        column-gap: 18px;
        row-gap: 2px;
        padding: 18px 22px;
        margin: 0 0 32px 0;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        background: var(--card);
        color: var(--text-primary);
        text-decoration: none;
        transition: border-color 200ms ease, background 200ms ease, transform 200ms ease;
      }
      .manifesto-pointer:hover {
        border-color: var(--border-strong);
        background: var(--muted);
        opacity: 1;
      }
      .manifesto-pointer:hover .mp-arrow { transform: translateX(3px); }
      .mp-label {
        grid-area: label;
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-muted);
        padding-right: 18px;
        border-right: 1px solid var(--border);
      }
      .mp-title { grid-area: title; font-weight: 600; font-size: 15px; }
      .mp-hint { grid-area: hint; font-size: 13px; color: var(--text-muted); }
      .mp-arrow { grid-area: arrow; font-size: 16px; color: var(--text-muted); transition: transform 200ms ease; }
      @media (max-width: 640px) {
        .manifesto-pointer {
          grid-template-columns: 1fr auto;
          grid-template-areas: "label arrow" "title arrow" "hint arrow";
        }
        .mp-label { border-right: 0; padding-right: 0; padding-bottom: 4px; }
      }
    `}></style>
  </Fragment>

  <!-- Manifesto pointer -->
  <a href="/manifesto" class="manifesto-pointer">
    <span class="mp-label">Read first</span>
    <span class="mp-title">Why I'm building Sardis</span>
    <span class="mp-hint">A manifesto on agent autonomy, money, and why the primitive underneath matters.</span>
    <span class="mp-arrow" aria-hidden="true">→</span>
  </a>

  <!-- Hero -->
  <section class="hero">
    <span class="eyebrow">Technical Canvases · Sardis Protocol v1.0</span>
    <h1>The open-source financial authority layer for AI agents, explained end-to-end.</h1>
    <p class="hero-lead">
      Twenty-six canvases mapping every layer of Sardis — the monorepo, the 10 protocol objects,
      the 22-state payment lifecycle, the dual-rail ledger architecture, the multi-protocol gateway,
      the Facility Gate credit control plane, and the open-standards stack (OSP, FIDES, AGIT).
      Every claim sourced against live code.
    </p>
    <div class="row row-wrap mt-24" style="gap:12px;">
      <span class="badge">Live on Base mainnet</span>
      <span class="badge">Live on Tempo mainnet</span>
      <span class="badge badge-info">Agent Credit · New</span>
      <span class="badge">70K+ SDK installs</span>
      <span class="badge">15+ AI framework integrations</span>
      <span class="badge badge-muted">Open specification · Attribution required</span>
    </div>
  </section>

  <!-- AI summary bar -->
  <section class="section" style="padding-top:24px; border-top:0;">
    <div class="ai-bar">
      <div class="ai-bar-text">
        <strong>Short on time?</strong> The full text of every canvas is at
        <code>/llms-full.txt</code> — ~315&nbsp;KB, fits in any large-context model.
        Drop it into Claude, ChatGPT, or Gemini for a one-shot summary or targeted Q&amp;A.
      </div>
      <div class="ai-actions">
        <button class="ai-btn" data-copy-llms>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <span data-copy-label>Copy full text</span>
        </button>
        <a class="ai-btn ai-btn-primary" href="https://chatgpt.com/?hints=search&q=Summarize+the+architecture+of+Sardis+using+https%3A%2F%2Fcanvas.sardis.sh%2Fllms-full.txt" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" aria-hidden="true">
            <path d="M9.205 8.658v-2.26c0-.19.072-.333.238-.428l4.543-2.616c.619-.357 1.356-.523 2.117-.523 2.854 0 4.662 2.212 4.662 4.566 0 .167 0 .357-.024.547l-4.71-2.759a.797.797 0 00-.856 0l-5.97 3.473zm10.609 8.8V12.06c0-.333-.143-.57-.429-.737l-5.97-3.473 1.95-1.118a.433.433 0 01.476 0l4.543 2.617c1.309.76 2.189 2.378 2.189 3.948 0 1.808-1.07 3.473-2.76 4.163zM7.802 12.703l-1.95-1.142c-.167-.095-.239-.238-.239-.428V5.899c0-2.545 1.95-4.472 4.591-4.472 1 0 1.927.333 2.712.928L8.23 5.067c-.285.166-.428.404-.428.737v6.898zM12 15.128l-2.795-1.57v-3.33L12 8.658l2.795 1.57v3.33L12 15.128zm1.796 7.23c-1 0-1.927-.332-2.712-.927l4.686-2.712c.285-.166.428-.404.428-.737v-6.898l1.974 1.142c.167.095.238.238.238.428v5.233c0 2.545-1.974 4.472-4.614 4.472zm-5.637-5.303l-4.544-2.617c-1.308-.761-2.188-2.378-2.188-3.948A4.482 4.482 0 014.21 6.327v5.423c0 .333.143.571.428.738l5.947 3.449-1.95 1.118a.432.432 0 01-.476 0zm-.262 3.9c-2.688 0-4.662-2.021-4.662-4.519 0-.19.024-.38.047-.57l4.686 2.71c.286.167.571.167.856 0l5.97-3.448v2.26c0 .19-.07.333-.237.428l-4.543 2.616c-.619.357-1.356.523-2.117.523zm5.899 2.83a5.947 5.947 0 005.827-4.756C22.287 18.339 24 15.84 24 13.296c0-1.665-.713-3.282-1.998-4.448.119-.5.19-.999.19-1.498 0-3.401-2.759-5.947-5.946-5.947-.642 0-1.26.095-1.88.31A5.962 5.962 0 0010.205 0a5.947 5.947 0 00-5.827 4.757C1.713 5.447 0 7.945 0 10.49c0 1.666.713 3.283 1.998 4.448-.119.5-.19 1-.19 1.499 0 3.401 2.759 5.946 5.946 5.946.642 0 1.26-.095 1.88-.309a5.96 5.96 0 004.162 1.713z"/>
          </svg>
          <span>Ask ChatGPT</span>
        </a>
        <a class="ai-btn" href="https://claude.ai/new?q=Summarize+the+architecture+of+Sardis+using+this+technical+map%3A+https%3A%2F%2Fcanvas.sardis.sh%2Fllms-full.txt" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" aria-hidden="true">
            <path d="M4.709 15.955l4.72-2.647.08-.23-.08-.128H9.2l-.79-.048-2.698-.073-2.339-.097-2.266-.122-.571-.121L0 11.784l.055-.352.48-.321.686.06 1.52.103 2.278.158 1.652.097 2.449.255h.389l.055-.157-.134-.098-.103-.097-2.358-1.596-2.552-1.688-1.336-.972-.724-.491-.364-.462-.158-1.008.656-.722.881.06.225.061.893.686 1.908 1.476 2.491 1.833.365.304.145-.103.019-.073-.164-.274-1.355-2.446-1.446-2.49-.644-1.032-.17-.619a2.97 2.97 0 01-.104-.729L6.283.134 6.696 0l.996.134.42.364.62 1.414 1.002 2.229 1.555 3.03.456.898.243.832.091.255h.158V9.01l.128-1.706.237-2.095.23-2.695.08-.76.376-.91.747-.492.584.28.48.685-.067.444-.286 1.851-.559 2.903-.364 1.942h.212l.243-.242.985-1.306 1.652-2.064.73-.82.85-.904.547-.431h1.033l.76 1.129-.34 1.166-1.064 1.347-.881 1.142-1.264 1.7-.79 1.36.073.11.188-.02 2.856-.606 1.543-.28 1.841-.315.833.388.091.395-.328.807-1.969.486-2.309.462-3.439.813-.042.03.049.061 1.549.146.662.036h1.622l3.02.225.79.522.474.638-.079.485-1.215.62-1.64-.389-3.829-.91-1.312-.329h-.182v.11l1.093 1.068 2.006 1.81 2.509 2.33.127.578-.322.455-.34-.049-2.205-1.657-.851-.747-1.926-1.62h-.128v.17l.444.649 2.345 3.521.122 1.08-.17.353-.608.213-.668-.122-1.374-1.925-1.415-2.167-1.143-1.943-.14.08-.674 7.254-.316.37-.729.28-.607-.461-.322-.747.322-1.476.389-1.924.315-1.53.286-1.9.17-.632-.012-.042-.14.018-1.434 1.967-2.18 2.945-1.726 1.845-.414.164-.717-.37.067-.662.401-.589 2.388-3.036 1.44-1.882.93-1.086-.006-.158h-.055L4.132 18.56l-1.13.146-.487-.456.061-.746.231-.243 1.908-1.312-.006.006z"/>
          </svg>
          <span>Ask Claude</span>
        </a>
      </div>
    </div>
    <script is:inline>
      document.addEventListener("click", async (e) => {
        const btn = e.target.closest("[data-copy-llms]");
        if (!btn) return;
        e.preventDefault();
        const label = btn.querySelector("[data-copy-label]");
        const setLabel = (t) => { if (label) label.textContent = t; };
        const reset = () => { btn.dataset.state = ""; setLabel("Copy full text"); };
        btn.dataset.state = "loading";
        setLabel("Loading…");
        try {
          const res = await fetch("/llms-full.txt", { cache: "force-cache" });
          if (!res.ok) throw new Error("fetch failed");
          const text = await res.text();
          await navigator.clipboard.writeText(text);
          btn.dataset.state = "copied";
          const kb = Math.round(text.length / 1024);
          setLabel("Copied — " + kb + " KB, paste into any AI");
          setTimeout(reset, 3500);
        } catch (_) {
          btn.dataset.state = "error";
          setLabel("Couldn't copy — opening file");
          window.open("/llms-full.txt", "_blank");
          setTimeout(reset, 2500);
        }
      });
    </script>
  </section>

  <!-- Recommended -->
  <section class="section">
    <div class="section-header">
      <div class="eyebrow">Start here</div>
      <h2>Recommended reading.</h2>
      <p class="text-muted" style="max-width:720px;">
        If you read nothing else, read these five. They compound — each assumes a little of the previous.
        Starred in the sidebar so you can find them after you wander.
      </p>
    </div>
    <div class="rec-grid">
      {recommended.map((r) => (
        <a class="rec-card" href={`/${r.slug}`}>
          <div class="rec-num">
            <span class="rec-star" aria-hidden="true">★</span>
            <span>{r.num} · Recommended</span>
          </div>
          <div class="rec-title">{r.title}</div>
          <div class="rec-desc">{r.desc}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Snapshot stats -->
  <section class="section">
    <div class="section-header">
      <div class="eyebrow">Surface area — today</div>
      <h2>What "comprehensive" actually means.</h2>
      <p class="text-muted" style="max-width:720px;">
        Every number below is pulled from live repository state, not from docs.
        Docs drift; code is truth.
      </p>
    </div>
    <div class="grid grid-4">
      <div class="stat"><div class="stat-value">10</div><div class="stat-label">Protocol Objects</div></div>
      <div class="stat"><div class="stat-value">22</div><div class="stat-label">Lifecycle States</div></div>
      <div class="stat"><div class="stat-value">12</div><div class="stat-label">Policy Checks</div></div>
      <div class="stat"><div class="stat-value">51</div><div class="stat-label">Monorepo Packages</div></div>
      <div class="stat"><div class="stat-value">123</div><div class="stat-label">API Routers</div></div>
      <div class="stat"><div class="stat-value">107</div><div class="stat-label">DB Migrations</div></div>
      <div class="stat"><div class="stat-value">9</div><div class="stat-label">Solidity Contracts</div></div>
      <div class="stat"><div class="stat-value">25+</div><div class="stat-label">External Services</div></div>
    </div>
  </section>

  <!-- Full canvas grid -->
  <section class="section">
    <div class="section-header">
      <div class="eyebrow">All canvases</div>
      <h2>Pick any.</h2>
      <p class="text-muted" style="max-width:720px;">
        Each canvas is self-contained: the "what," the "why," and the "how this thing is wired."
      </p>
    </div>
    <div class="canvas-index-grid" data-canvas-grid></div>
  </section>

  <!-- How to read -->
  <section class="section">
    <div class="section-header">
      <div class="eyebrow">Conventions</div>
      <h2>How to read these.</h2>
    </div>
    <div class="grid grid-2">
      <div class="card">
        <div class="card-title">Every claim is sourced</div>
        <div class="card-description">
          When a canvas names a file, a router, or a migration, it's because that thing exists today
          in the Sardis monorepo. File paths are literal. If something has drifted, trust the code.
        </div>
      </div>
      <div class="card">
        <div class="card-title">"Why" is load-bearing</div>
        <div class="card-description">
          Knowing what a module does is cheap — grep finds it. Knowing why it's shaped that way
          (a past incident, a compliance constraint, a protocol quirk) is the hard part. The canvases
          spend more words on why than what.
        </div>
      </div>
      <div class="card">
        <div class="card-title">Monokrom on purpose</div>
        <div class="card-description">
          No gradients, no accent colors fighting for attention, no emoji icons. The public
          canvases use a restrained monochrome system so architecture, policy, and protocol details
          stay readable.
        </div>
      </div>
      <div class="card">
        <div class="card-title">AI-friendly by design</div>
        <div class="card-description">
          <code>llms.txt</code> (table of contents) and <code>llms-full.txt</code> (full concatenated
          text) live at the root. Any large-context model can ingest the whole stack and answer
          specific questions — faster than reading linearly.
        </div>
      </div>
    </div>
  </section>

  <footer style="margin-top:64px; padding-top:32px; border-top:1px solid var(--border); font-size:12.5px; color:var(--text-muted); font-family:var(--font-mono);">
    Sardis Protocol v1.0 · Open Specification · Attribution required ·
    <a href="https://sardis.sh">sardis.sh</a> ·
    <a href="https://github.com/EfeDurmaz16/sardis">github</a>
  </footer>
</Canvas>
