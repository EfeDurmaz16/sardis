---
import { ClientRouter } from "astro:transitions";
interface Props {
  title: string;
  description?: string;
  currentId: string;
  canvasNum?: string;
  extraHead?: string;
}
const {
  title,
  description = "Sardis, the open-source financial authority layer for AI agents. Technical canvases.",
  currentId,
} = Astro.props;

const canvasUrl = `https://canvas.sardis.sh/${currentId === "index" ? "" : currentId}`;
const aiPrompts: Record<string, string> = {
  manifesto: `Read this manifesto by the founder of Sardis and summarize the thesis, the personal story, and the case for an open standard for agent payments: ${canvasUrl}`,
  index: `Summarize what Sardis is, who it is for, and how the product fits together from this overview: ${canvasUrl}`,
  "repo-structure": `Walk me through the Sardis monorepo layout and explain how the packages relate to each other: ${canvasUrl}`,
  packages: `Summarize the Sardis package catalogue and point out which packages are core runtime vs integrations vs SDKs: ${canvasUrl}`,
  architecture: `Summarize the Sardis system architecture and pull out the non-obvious design choices: ${canvasUrl}`,
  "api-surface": `Summarize the Sardis API surface. Group the routers by domain and flag anything unusual about the endpoint design: ${canvasUrl}`,
  database: `Summarize the Sardis data model. Highlight the tables that carry security or audit guarantees: ${canvasUrl}`,
  contracts: `Summarize the Sardis smart contracts and call out the trust and upgrade assumptions: ${canvasUrl}`,
  "wallet-mpc": `Explain how Sardis handles wallet custody and MPC signing, and point out the non-obvious security choices: ${canvasUrl}`,
  "policy-engine": `Summarize the Sardis spending policy engine and the guardrails that bind agent authority: ${canvasUrl}`,
  compliance: `Summarize the Sardis compliance stack (KYC, AML, sanctions) and how it fails closed: ${canvasUrl}`,
  security: `Summarize the Sardis security model. Pull out the threat assumptions and the non-obvious mitigations: ${canvasUrl}`,
  "payment-flow": `Walk me through the Sardis payment flow end to end and flag where authority is checked: ${canvasUrl}`,
  settlement: `Summarize how Sardis settles payments and where the non-obvious correctness guarantees live: ${canvasUrl}`,
  "state-machine": `Summarize the Sardis transaction state machine. Flag any states that are easy to misunderstand: ${canvasUrl}`,
  "dual-rail": `Summarize the Sardis dual-rail design (stablecoin + card) and why it exists: ${canvasUrl}`,
  credit: `Summarize Sardis Facility Gate and explain how the agent credit architecture stays non-custodial while still allowing partner-backed facility access: ${canvasUrl}`,
  checkout: `Summarize Pay with Sardis (checkout) and its non-obvious architectural choices: ${canvasUrl}`,
  protocols: `Summarize the agent payment protocols Sardis implements (AP2, TAP, x402) and how they compose: ${canvasUrl}`,
  "protocol-objects": `Summarize the Sardis protocol object model (mandates, carts, receipts) and how they chain: ${canvasUrl}`,
  "sardis-connect": `Summarize Sardis Connect and what problem it solves for enterprise integrators: ${canvasUrl}`,
  "zk-privacy": `Summarize how Sardis uses ZK proofs for policy privacy and what it buys you: ${canvasUrl}`,
  "osp-integration": `Summarize how Sardis integrates with the Open Service Protocol and the boundary between them: ${canvasUrl}`,
  integrations: `Summarize the Sardis framework and provider integrations and how the adapter layer is organized: ${canvasUrl}`,
  sdks: `Summarize the Sardis SDKs (Python, JS, MCP, CLI) and the surface they expose: ${canvasUrl}`,
  dashboard: `Summarize the Sardis dashboard — what it shows and how it is wired to the API: ${canvasUrl}`,
  cicd: `Summarize the Sardis CI/CD and deployment topology and any non-obvious release choices: ${canvasUrl}`,
  external: `Summarize the external services Sardis depends on and where each one sits in the stack: ${canvasUrl}`,
};
const aiPrompt = aiPrompts[currentId] ?? `Summarize this Sardis canvas and pull out the non-obvious architectural choices: ${canvasUrl}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <meta name="theme-color" content="#1a1614" />
    {/* Warm up the Mermaid CDN early so lazy-load feels instant on first diagram */}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preload" as="script" href="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js" />
    {/* Inline theme script — runs BEFORE render on first load to avoid flash */}
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var t = localStorage.getItem("sardis-canvas-theme");
            if (!t) t = "dark";
            document.documentElement.setAttribute("data-theme", t);
          } catch (_) {
            document.documentElement.setAttribute("data-theme", "dark");
          }
        }
        applyTheme();
        // Astro ClientRouter resets html attributes on swap — re-apply on each nav
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/base.css" />
    <slot name="head" />
    <ClientRouter />
  </head>
  <body data-canvas={currentId}>
    <button
      class="mobile-menu-btn"
      aria-label="Open navigation"
      data-mobile-menu-btn
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <div class="sidebar-scrim" data-sidebar-scrim></div>

    <button class="sidebar-open-btn" aria-label="Show navigation" data-sidebar-open>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>

    <div class="canvas-page" data-canvas-page>
      <aside
        class="canvas-sidebar"
        data-canvas-sidebar
        data-current={currentId}
        transition:persist="sardis-sidebar"
      ></aside>

      <main class="canvas-main">
        {currentId !== "index" && (
          <aside class="page-ai page-ai-top" aria-label="AI assist">
            <div class="page-ai-head">
              <span class="eyebrow">AI summary</span>
              <span class="page-ai-hint">Have a model read this canvas for you.</span>
            </div>
            <div class="page-ai-actions">
              <button class="ai-btn" data-page-copy type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <span data-page-copy-label>Copy this canvas</span>
              </button>
              <a
                class="ai-btn ai-btn-primary"
                data-page-chatgpt
                href={`https://chatgpt.com/?hints=search&q=${encodeURIComponent(aiPrompt)}`}
                target="_blank"
                rel="noopener"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" aria-hidden="true">
                  <path d="M9.205 8.658v-2.26c0-.19.072-.333.238-.428l4.543-2.616c.619-.357 1.356-.523 2.117-.523 2.854 0 4.662 2.212 4.662 4.566 0 .167 0 .357-.024.547l-4.71-2.759a.797.797 0 00-.856 0l-5.97 3.473zm10.609 8.8V12.06c0-.333-.143-.57-.429-.737l-5.97-3.473 1.95-1.118a.433.433 0 01.476 0l4.543 2.617c1.309.76 2.189 2.378 2.189 3.948 0 1.808-1.07 3.473-2.76 4.163zM7.802 12.703l-1.95-1.142c-.167-.095-.239-.238-.239-.428V5.899c0-2.545 1.95-4.472 4.591-4.472 1 0 1.927.333 2.712.928L8.23 5.067c-.285.166-.428.404-.428.737v6.898zM12 15.128l-2.795-1.57v-3.33L12 8.658l2.795 1.57v3.33L12 15.128zm1.796 7.23c-1 0-1.927-.332-2.712-.927l4.686-2.712c.285-.166.428-.404.428-.737v-6.898l1.974 1.142c.167.095.238.238.238.428v5.233c0 2.545-1.974 4.472-4.614 4.472zm-5.637-5.303l-4.544-2.617c-1.308-.761-2.188-2.378-2.188-3.948A4.482 4.482 0 014.21 6.327v5.423c0 .333.143.571.428.738l5.947 3.449-1.95 1.118a.432.432 0 01-.476 0zm-.262 3.9c-2.688 0-4.662-2.021-4.662-4.519 0-.19.024-.38.047-.57l4.686 2.71c.286.167.571.167.856 0l5.97-3.448v2.26c0 .19-.07.333-.237.428l-4.543 2.616c-.619.357-1.356.523-2.117.523zm5.899 2.83a5.947 5.947 0 005.827-4.756C22.287 18.339 24 15.84 24 13.296c0-1.665-.713-3.282-1.998-4.448.119-.5.19-.999.19-1.498 0-3.401-2.759-5.947-5.946-5.947-.642 0-1.26.095-1.88.31A5.962 5.962 0 0010.205 0a5.947 5.947 0 00-5.827 4.757C1.713 5.447 0 7.945 0 10.49c0 1.666.713 3.283 1.998 4.448-.119.5-.19 1-.19 1.499 0 3.401 2.759 5.946 5.946 5.946.642 0 1.26-.095 1.88-.309a5.96 5.96 0 004.162 1.713z"/>
                </svg>
                <span>Ask ChatGPT</span>
              </a>
              <a
                class="ai-btn"
                data-page-claude
                href={`https://claude.ai/new?q=${encodeURIComponent(aiPrompt)}`}
                target="_blank"
                rel="noopener"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" aria-hidden="true">
                  <path d="M4.709 15.955l4.72-2.647.08-.23-.08-.128H9.2l-.79-.048-2.698-.073-2.339-.097-2.266-.122-.571-.121L0 11.784l.055-.352.48-.321.686.06 1.52.103 2.278.158 1.652.097 2.449.255h.389l.055-.157-.134-.098-.103-.097-2.358-1.596-2.552-1.688-1.336-.972-.724-.491-.364-.462-.158-1.008.656-.722.881.06.225.061.893.686 1.908 1.476 2.491 1.833.365.304.145-.103.019-.073-.164-.274-1.355-2.446-1.446-2.49-.644-1.032-.17-.619a2.97 2.97 0 01-.104-.729L6.283.134 6.696 0l.996.134.42.364.62 1.414 1.002 2.229 1.555 3.03.456.898.243.832.091.255h.158V9.01l.128-1.706.237-2.095.23-2.695.08-.76.376-.91.747-.492.584.28.48.685-.067.444-.286 1.851-.559 2.903-.364 1.942h.212l.243-.242.985-1.306 1.652-2.064.73-.82.85-.904.547-.431h1.033l.76 1.129-.34 1.166-1.064 1.347-.881 1.142-1.264 1.7-.79 1.36.073.11.188-.02 2.856-.606 1.543-.28 1.841-.315.833.388.091.395-.328.807-1.969.486-2.309.462-3.439.813-.042.03.049.061 1.549.146.662.036h1.622l3.02.225.79.522.474.638-.079.485-1.215.62-1.64-.389-3.829-.91-1.312-.329h-.182v.11l1.093 1.068 2.006 1.81 2.509 2.33.127.578-.322.455-.34-.049-2.205-1.657-.851-.747-1.926-1.62h-.128v.17l.444.649 2.345 3.521.122 1.08-.17.353-.608.213-.668-.122-1.374-1.925-1.415-2.167-1.143-1.943-.14.08-.674 7.254-.316.37-.729.28-.607-.461-.322-.747.322-1.476.389-1.924.315-1.53.286-1.9.17-.632-.012-.042-.14.018-1.434 1.967-2.18 2.945-1.726 1.845-.414.164-.717-.37.067-.662.401-.589 2.388-3.036 1.44-1.882.93-1.086-.006-.158h-.055L4.132 18.56l-1.13.146-.487-.456.061-.746.231-.243 1.908-1.312-.006.006z"/>
                </svg>
                <span>Ask Claude</span>
              </a>
            </div>
          </aside>
        )}

        <slot />
      </main>
    </div>

    <script is:inline>
      // Lazy-load Mermaid only on pages that actually need it. Saves ~500KB for
      // the roughly half of canvases without diagrams.
      (function () {
        let mermaidPromise = null;
        function loadMermaid() {
          if (!mermaidPromise) {
            mermaidPromise = new Promise((resolve) => {
              const s = document.createElement("script");
              s.src = "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js";
              s.async = true;
              s.onload = () => resolve(window.mermaid);
              document.head.appendChild(s);
            });
          }
          return mermaidPromise;
        }
        function mermaidThemeVars() {
          const dark = document.documentElement.getAttribute("data-theme") === "dark";
          if (dark) {
            return {
              fontFamily: "Geist Mono, ui-monospace, monospace",
              background: "#222222",
              primaryColor: "#2a2a2a",
              primaryTextColor: "#ededed",
              primaryBorderColor: "#4a4a4a",
              secondaryColor: "#2e2e2e",
              secondaryTextColor: "#ededed",
              secondaryBorderColor: "#4a4a4a",
              tertiaryColor: "#282828",
              tertiaryTextColor: "#ededed",
              tertiaryBorderColor: "#4a4a4a",
              lineColor: "#8a8a8a",
              textColor: "#ededed",
              mainBkg: "#2a2a2a",
              secondBkg: "#2e2e2e",
              noteBkgColor: "#2e2e2e",
              noteTextColor: "#ededed",
              noteBorderColor: "#4a4a4a",
              actorBkg: "#2a2a2a",
              actorBorder: "#6a6a6a",
              actorTextColor: "#ededed",
              actorLineColor: "#8a8a8a",
              signalColor: "#bbbbbb",
              signalTextColor: "#ededed",
              labelBoxBkgColor: "#2a2a2a",
              labelBoxBorderColor: "#6a6a6a",
              labelTextColor: "#ededed",
              loopTextColor: "#ededed",
              altBackground: "#282828",
              edgeLabelBackground: "#222222",
              clusterBkg: "#1f1f1f",
              clusterBorder: "#4a4a4a",
              // Flowchart-specific
              nodeBkg: "#2a2a2a",
              nodeBorder: "#6a6a6a",
              nodeTextColor: "#ededed",
              // State diagram
              stateBkg: "#2a2a2a",
              stateLabelColor: "#ededed",
              // Sequence
              activationBorderColor: "#8a8a8a",
              activationBkgColor: "#2a2a2a",
              sequenceNumberColor: "#111111",
            };
          }
          return {
            fontFamily: "Geist Mono, ui-monospace, monospace",
            background: "#ffffff",
            primaryColor: "#ffffff",
            primaryTextColor: "#111111",
            primaryBorderColor: "#d4d4d4",
            lineColor: "#888888",
            secondaryColor: "#f7f7f7",
            tertiaryColor: "#fafafa",
            noteBkgColor: "#f7f7f7",
            noteTextColor: "#111111",
            actorBkg: "#ffffff",
            actorBorder: "#d4d4d4",
            actorTextColor: "#111111",
            signalColor: "#666666",
            signalTextColor: "#111111",
          };
        }

        async function initMermaidIfNeeded() {
          const nodes = document.querySelectorAll('.mermaid:not([data-processed="true"])');
          if (!nodes.length) return;
          const m = await loadMermaid();
          if (!m) return;
          m.initialize({
            startOnLoad: false,
            theme: "base",
            themeVariables: mermaidThemeVars(),
          });
          try { m.run({ nodes: Array.from(nodes) }); } catch (_) {}
        }

        async function rerenderMermaidForTheme() {
          // Theme changed — clear processed flag and re-run mermaid so colors match
          const nodes = document.querySelectorAll(".mermaid");
          if (!nodes.length) return;
          const m = await loadMermaid();
          if (!m) return;
          nodes.forEach((n) => {
            const original = n.getAttribute("data-original-source");
            if (original != null) {
              n.textContent = original;
            } else {
              // Capture original source once so re-runs work after first render
              n.setAttribute("data-original-source", n.textContent);
            }
            n.removeAttribute("data-processed");
          });
          m.initialize({ startOnLoad: false, theme: "base", themeVariables: mermaidThemeVars() });
          try { m.run({ nodes: Array.from(nodes) }); } catch (_) {}
        }

        document.addEventListener("DOMContentLoaded", initMermaidIfNeeded);
        document.addEventListener("astro:page-load", initMermaidIfNeeded);
        // Listen for theme flips (MutationObserver on data-theme)
        const mo = new MutationObserver((muts) => {
          for (const m of muts) {
            if (m.type === "attributes" && m.attributeName === "data-theme") {
              rerenderMermaidForTheme();
            }
          }
        });
        mo.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
      })();
    </script>
    <script is:inline>
      // Per-page "Copy this canvas" handler — extracts the main content text
      // and puts it on the clipboard.
      document.addEventListener("click", async (e) => {
        const btn = e.target.closest("[data-page-copy]");
        if (!btn) return;
        e.preventDefault();
        const label = btn.querySelector("[data-page-copy-label]");
        const set = (t) => { if (label) label.textContent = t; };
        const reset = () => { btn.dataset.state = ""; set("Copy this canvas"); };
        try {
          const main = document.querySelector(".canvas-main");
          if (!main) throw new Error("no main");
          // Clone and remove the AI bar itself from the copy
          const clone = main.cloneNode(true);
          clone.querySelectorAll(".page-ai, script, style").forEach((n) => n.remove());
          const text = (clone.innerText || "").replace(/\n{3,}/g, "\n\n").trim();
          await navigator.clipboard.writeText(text);
          btn.dataset.state = "copied";
          const kb = Math.round(text.length / 1024);
          set("Copied — " + (kb || "<1") + " KB, paste into any AI");
          setTimeout(reset, 3000);
        } catch (_) {
          btn.dataset.state = "error";
          set("Couldn't copy");
          setTimeout(reset, 2000);
        }
      });
    </script>
    <script is:inline src="/js/nav.js?v=4"></script>
  </body>
</html>
