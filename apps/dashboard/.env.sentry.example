# Sentry observability — copy into .env.local and fill in
#
# Get these from https://sentry.io/settings/sardis-labs/projects/sardis-dashboard/keys/
#
# The setup is fail-safe: leave all these unset and Sentry becomes a no-op
# (no errors captured, no build-time instrumentation, no network calls).
# withSentryConfig in next.config.ts only wraps when SENTRY_DSN is present.

# --- Required for runtime error capture ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Required for source map upload at build time ---
SENTRY_ORG=sardis-labs
SENTRY_PROJECT=sardis-dashboard
# Create at https://sardis-labs.sentry.io/settings/auth-tokens/
# Scope: project:releases
SENTRY_AUTH_TOKEN=

# --- Sampling (tune in production) ---
# 10% of transactions traced — raise for deeper perf visibility
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# 10% of errored sessions replayed for reproduction
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR=0.1
