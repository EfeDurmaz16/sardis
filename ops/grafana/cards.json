{
  "schemaVersion": 39,
  "uid": "sardis-cards",
  "title": "Sardis — Virtual Cards",
  "tags": ["sardis", "cards"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Card Transaction Volume (txns/s)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(sardis_card_transactions_total[5m])) by (provider, status)",
          "legendFormat": "{{provider}} — {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Decline Rate by Provider",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(rate(sardis_card_declines_total[5m])) by (provider) / sum(rate(sardis_card_transactions_total[5m])) by (provider)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true }
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Decline Reasons",
      "gridPos": { "x": 0, "y": 8, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(sardis_card_declines_total) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "options": { "displayLabels": ["percent", "name"], "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 4,
      "type": "barchart",
      "title": "Transaction Volume by Provider",
      "gridPos": { "x": 10, "y": 8, "w": 14, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(sardis_card_transactions_total) by (provider)",
          "legendFormat": "{{provider}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "xField": "provider",
        "orientation": "vertical",
        "tooltip": { "mode": "single" }
      }
    }
  ]
}
