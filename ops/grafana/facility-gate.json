{
  "schemaVersion": 39,
  "title": "Sardis Facility Gate",
  "tags": ["sardis", "facility-gate"],
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Authorization Failures",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(sardis_facility_gate_authorization_failures_total[5m]))",
          "legendFormat": "failures"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Adapter Errors",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(sardis_facility_gate_adapter_errors_total[5m]))",
          "legendFormat": "errors"
        }
      ]
    }
  ]
}
