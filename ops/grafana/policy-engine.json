{
  "schemaVersion": 39,
  "uid": "sardis-policy-engine",
  "title": "Sardis — Policy Engine",
  "tags": ["sardis", "policy"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Policy Check Rate (checks/s)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(sardis_policy_checks_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Denial Rate %",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(rate(sardis_policy_denials_total[5m])) / sum(rate(sardis_policy_checks_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Approval Queue Depth",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sardis_approval_queue_depth",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true }
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "Denial Reasons",
      "gridPos": { "x": 0, "y": 8, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(sardis_policy_denials_total) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "options": { "displayLabels": ["percent", "name"], "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Denial Spike Alerts",
      "gridPos": { "x": 10, "y": 8, "w": 14, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(sardis_policy_denial_spikes_total[5m])",
          "legendFormat": "Denial Spikes",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(sardis_policy_denial_burst_window_bucket[5m]))",
          "legendFormat": "Burst Window p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    }
  ]
}
