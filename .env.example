SARDIS_STRIPE_CONNECT_WEBHOOK_SECRET=
# Return/refresh URLs for merchant onboarding (set to your hosted operator surface)
# SARDIS_CONNECT_RETURN_URL=https://merchant.example.com/sardis/connect/complete
# SARDIS_CONNECT_REFRESH_URL=https://merchant.example.com/sardis/connect/refresh

# ===========================================================================
# Production overrides (formerly .env.production.example)
# ===========================================================================
# =============================================================================
# Sardis Production Environment Configuration
# =============================================================================
# Copy to .env and fill in values before deploying to production.
# NEVER commit .env or any file with real secrets to version control.
#
# Legend:
#   [REQUIRED]  — must be set for production to start/function
#   [REQUIRED*] — required for live chain mode (on-chain transactions)
#   [OPTIONAL]  — enhances functionality but not required for launch
#
# For Cloud Run: secrets are managed via GCP Secret Manager.
# For local: set directly in .env file.
# =============================================================================

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# [REQUIRED] Environment identifier — enables strict checks, fail-closed defaults
SARDIS_ENVIRONMENT=prod

# [REQUIRED] Chain execution mode
SARDIS_CHAIN_MODE=live
SARDIS_EXECUTION_MODE=production_live

# [REQUIRED] API server binding
SARDIS_API_HOST=0.0.0.0
SARDIS_API_PORT=8000
SARDIS_API_BASE_URL=https://api.sardis.sh

# [REQUIRED] Default chain for API calls and health checks
SARDIS_DEFAULT_CHAIN=base
SARDIS_HEALTH_CHAIN=base

# =============================================================================
# DATABASE
# =============================================================================

# [REQUIRED] PostgreSQL connection string (Neon serverless recommended)
# Example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/sardis?sslmode=require
DATABASE_URL=

# [OPTIONAL] Read replica for dashboard/analytics queries
# SARDIS_DATABASE_REPLICA_URL=

# [OPTIONAL] Connection pool tuning (defaults are fine for Neon)
# SARDIS_DB_POOL_MIN_NEON=2
# SARDIS_DB_POOL_MAX_NEON=15

# =============================================================================
# SECRETS & AUTH
# =============================================================================

# [REQUIRED] Application secret key — generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SARDIS_SECRET_KEY=

# [REQUIRED] JWT signing secret for dashboard sessions (HS256)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# [REQUIRED] Admin password (strong, unique)
SARDIS_ADMIN_PASSWORD=

# [OPTIONAL] JWT token lifetime
# JWT_EXPIRATION_HOURS=24

# [OPTIONAL] OAuth (Google sign-in for your hosted operator surface)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# =============================================================================
# CORS & NETWORK
# =============================================================================

# [REQUIRED] Allowed origins (production domains only; add your hosted product origins explicitly)
SARDIS_ALLOWED_ORIGINS=https://sardis.sh,https://www.sardis.sh

# [OPTIONAL] Trusted proxy IPs for rate-limiter source IP extraction
SARDIS_TRUSTED_PROXIES=

# =============================================================================
# REDIS / CACHE
# =============================================================================

# [REQUIRED] Redis URL — required for rate limiting, dedup, and replay cache in production
# Example: rediss://default:xxx@xxx.upstash.io:6379
SARDIS_REDIS_URL=

# =============================================================================
# MPC / CUSTODY (Required for live chain mode)
# =============================================================================

# [REQUIRED*] MPC provider — must be "turnkey" for non-custodial production
SARDIS_MPC__NAME=turnkey
SARDIS_MPC__API_BASE=https://api.turnkey.com

# [REQUIRED*] Turnkey API credentials
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=

# =============================================================================
# RPC ENDPOINTS (Required for live chain mode)
# =============================================================================
# Use dedicated RPC providers (Alchemy, Infura, QuickNode) — not public endpoints.

# [REQUIRED*] Base mainnet (primary chain)
SARDIS_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# [OPTIONAL] Additional chain RPCs (enable as needed)
# SARDIS_POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# SARDIS_ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# SARDIS_ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# SARDIS_OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY

# [REQUIRED*] Tempo mainnet
SARDIS_TEMPO_RPC_URL=https://rpc.tempo.xyz

# [OPTIONAL] Tempo testnet (for staging/testing)
# SARDIS_TEMPO_TESTNET_RPC_URL=https://rpc.testnet.tempo.xyz

# =============================================================================
# SMART CONTRACT ADDRESSES — BASE MAINNET
# =============================================================================
# Set after deploying with: ./scripts/deploy-mainnet-contracts.sh
# See contracts/deployments/base.json for lifecycle status.

# [REQUIRED*] Core contracts (deploy with scripts/deploy-mainnet-contracts.sh)
SARDIS_BASE_LEDGER_ANCHOR_ADDRESS=
SARDIS_BASE_REFUND_PROTOCOL_ADDRESS=

# [REQUIRED*] ERC-8183 contracts
SARDIS_ERC8183_ENABLED=true
SARDIS_ERC8183_CONTRACT_ADDRESS=
SARDIS_BASE_JOB_REGISTRY_ADDRESS=
SARDIS_BASE_JOB_MANAGER_ADDRESS=

# Pre-deployed (do not change unless upgrading)
# Zodiac Roles (policy module): 0x9646fDAD06d3e24444381f44362a3B0eB343D337
# Circle Paymaster: 0x0578cFB241215b77442a541325d6A4E6dFE700Ec
# Safe ProxyFactory: 0xa6B71E26C5e0845f74c812102Ca7114b6a896AB2
# Base USDC: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# =============================================================================
# SMART CONTRACT ADDRESSES — TEMPO MAINNET (already deployed)
# =============================================================================
# All 7 contracts deployed on Tempo Presto mainnet (chain ID 4217).
# Deployer: 0x99085505f506576c5C5342cAFEf14d6be43e0E9C

# SARDIS_TEMPO_LEDGER_ANCHOR_ADDRESS=0x9a5D2a6c81414FD1E6a2c9b55306c6D0b954b98B
# SARDIS_TEMPO_REFUND_PROTOCOL_ADDRESS=0x801ea29ca523ea16475e3def938002d6be985e9d
# SARDIS_TEMPO_IDENTITY_REGISTRY_ADDRESS=0xc5a3eb812bef4b883a2e890865de9d51818ac90a
# SARDIS_TEMPO_JOB_REGISTRY_ADDRESS=0x19eeeb6b349cfd4025cc75fa99bb36f6b8bec62d
# SARDIS_TEMPO_JOB_MANAGER_ADDRESS=0x758114d2229d3da2a8629b96b0394a3e8319fbb0
# SARDIS_TEMPO_REPUTATION_REGISTRY_ADDRESS=0x127ac64f6ddf7292e8dee43e39f4e66af859e704
# SARDIS_TEMPO_VALIDATION_REGISTRY_ADDRESS=0xc95e58f9e1df9c3df4593632846eb2a02cf73d6b

# =============================================================================
# CCTP V2 (same addresses across all EVM chains)
# =============================================================================

CCTP_TOKEN_MESSENGER_V2=0x28b5a0e9C621a5BadaA536219b3a228C8168cf5d
CCTP_MESSAGE_TRANSMITTER_V2=0x81D40F21F12A8F0E3252Bccb954D722d4c464B64

# =============================================================================
# PAYMASTER
# =============================================================================

# [REQUIRED*] Circle Paymaster (permissionless, no API key needed)
SARDIS_PAYMASTER_PROVIDER=circle
# Mainnet: 0x0578cFB241215b77442a541325d6A4E6dFE700Ec
# Testnet: 0x3BA9A96eE3eFf3A69E2B18886AcF52027EFF8966

# =============================================================================
# TAP (Trust Anchor Protocol)
# =============================================================================

# [REQUIRED] Enable TAP request verification in production
SARDIS_TAP_ENFORCEMENT=enabled

# [REQUIRED] JWKS URL for TAP signature verification
SARDIS_TAP_JWKS_URL=

# [OPTIONAL] TAP timing controls
# SARDIS_TAP_MAX_TIME_WINDOW=300
# SARDIS_TAP_NONCE_TTL=600

# =============================================================================
# PLATFORM FEES & TREASURY
# =============================================================================

# [OPTIONAL] Platform fee in basis points (50 = 0.50%)
SARDIS_PLATFORM_FEE_BPS=50

# [OPTIONAL] Fee collection wallet address on Base
SARDIS_TREASURY_ADDRESS=

# [OPTIONAL] Skip fee for amounts under this threshold (USD)
SARDIS_FEE_MIN_AMOUNT=1.00

# =============================================================================
# BILLING (Stripe)
# =============================================================================

# [OPTIONAL] Enable billing via Stripe
# SARDIS_BILLING_BILLING_ENABLED=true
# SARDIS_BILLING_STRIPE_SECRET_KEY=
# SARDIS_BILLING_STRIPE_WEBHOOK_SECRET=
# SARDIS_BILLING_STRIPE_PRICE_STARTER=
# SARDIS_BILLING_STRIPE_PRICE_GROWTH=

# =============================================================================
# COMPLIANCE
# =============================================================================

# [OPTIONAL] Persona KYC
# PERSONA_API_KEY=
# PERSONA_TEMPLATE_ID=
# PERSONA_WEBHOOK_SECRET=

# [OPTIONAL] Elliptic sanctions screening
# ELLIPTIC_API_KEY=
# ELLIPTIC_API_SECRET=
# ELLIPTIC_RISK_THRESHOLD=0.7

# =============================================================================
# VIRTUAL CARDS
# =============================================================================

# [OPTIONAL] Primary card provider: lithic | stripe_issuing
# SARDIS_CARDS_PRIMARY_PROVIDER=stripe_issuing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# =============================================================================
# FIAT ON/OFF-RAMP
# =============================================================================

# [OPTIONAL] Coinbase Onramp (hosted, free)
# COINBASE_APP_ID=
# COINBASE_CDP_API_KEY_NAME=
# COINBASE_CDP_API_KEY_PRIVATE_KEY=

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# [OPTIONAL] Sentry error tracking
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# [OPTIONAL] PostHog analytics
# POSTHOG_API_KEY=

# [OPTIONAL] OpenTelemetry distributed tracing
# SARDIS_OTEL_ENABLED=true
# SARDIS_OTEL_SERVICE_NAME=sardis-api
# SARDIS_OTEL_EXPORTER=sentry
# SARDIS_OTEL_SAMPLE_RATE=0.1

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# [OPTIONAL] Email (Resend or SMTP)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=re_xxx
# SMTP_FROM_EMAIL=noreply@sardis.sh
# SMTP_USE_TLS=true

# [OPTIONAL] Slack alerts
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# [OPTIONAL] Public signup (set false for invite-only launch)
SARDIS_ALLOW_PUBLIC_SIGNUP=false

# [OPTIONAL] KYA enforcement
# SARDIS_KYA_ENFORCEMENT_ENABLED=true
# SARDIS_KYA_STRICT_REGISTRATION=true

# [OPTIONAL] AGIT fail-closed (default in production)
# SARDIS_AGIT_FAIL_OPEN=false

# =============================================================================
# TRANSACTION CAPS (safety rails)
# =============================================================================

# [OPTIONAL] Global daily transaction cap (USD)
SARDIS_GLOBAL_DAILY_CAP=100000

# [OPTIONAL] Per-organization daily cap (USD)
SARDIS_DEFAULT_ORG_DAILY_CAP=10000

# [OPTIONAL] Per-agent per-transaction cap (USD)
SARDIS_DEFAULT_AGENT_TX_CAP=1000

# =============================================================================
# UNIFIED PROVIDER LAYER (capability ports)
# =============================================================================
# Every external money/identity service sits behind a typed capability port
# resolved by server.providers.registry.ProviderRegistry.  Each provider is
# ENV-GATED: it activates only when its keys below are set; otherwise a SANDBOX
# impl backs the capability so dev/test run green without live keys (fail-closed
# in production for required capabilities: CUSTODY, KYT).
#
# Every value below is a SERVER-ONLY SECRET unless marked PUBLIC/CONFIG.
# Capability matrix at runtime: GET /api/v2/providers/matrix
# Full reference: docs/providers.md

# ---- CUSTODY (key custody + signing) — required-in-production --------------
# Turnkey MPC (non-custodial). Get keys: https://app.turnkey.com (API Keys).
# Already used by the wallet/chain layer; the custody port reuses these.
# TURNKEY_API_PUBLIC_KEY=
# TURNKEY_API_PRIVATE_KEY=
# TURNKEY_ORGANIZATION_ID=

# ---- FIAT ACCOUNTS (bank-rail USD; partner-custodied) ----------------------
# Dakota (USDC-native fiat accounts). Get keys: https://dakota.xyz (dashboard).
# DAKOTA_API_KEY=
# DAKOTA_ENVIRONMENT=sandbox          # sandbox | production
# DAKOTA_WEBHOOK_PUBLIC_KEY=          # ed25519 pubkey (hex) for webhook verify
# Increase (FDIC partner-bank ACH/wire/RTP/FedNow). Get keys: https://dashboard.increase.com
# INCREASE_API_KEY=
# INCREASE_ENVIRONMENT=sandbox        # sandbox | production
# INCREASE_WEBHOOK_SECRET=
# Lithic (own-BIN treasury). Get keys: https://dashboard.lithic.com
# LITHIC_API_KEY=
# LITHIC_WEBHOOK_SECRET=
# LITHIC_ENVIRONMENT=sandbox

# ---- ONRAMP (fiat -> crypto session creation) ------------------------------
# Conduit (fiat -> USDC native on Tempo). Get keys: https://conduit.financial
# CONDUIT_API_KEY=
# CONDUIT_API_SECRET=
# CONDUIT_SANDBOX=true
# Onramper (aggregator). Get keys: https://onramper.com (dashboard).
# ONRAMPER_API_KEY=
# ONRAMPER_SIGNING_SECRET=
# ONRAMPER_ENVIRONMENT=staging        # staging | production
# Transak (widget). Get keys: https://dashboard.transak.com
# TRANSAK_API_KEY=
# TRANSAK_API_SECRET=
# TRANSAK_ENVIRONMENT=staging         # staging | production
# TRANSAK_REFERRER_DOMAIN=app.sardis.sh   # CONFIG (public)
# Daimo Pay. Get keys: https://pay.daimo.com
# DAIMO_PAY_API_KEY=
# DAIMO_ENVIRONMENT=sandbox

# ---- OFFRAMP (crypto -> fiat payout; partner-custodied) --------------------
# Circle CPN. Configured via SardisSettings.circle_cpn (see CIRCLE_CPN_* above).
# Onramper offramp reuses ONRAMPER_API_KEY (above).
# Transak Stream (payouts). Reuses TRANSAK_API_KEY or set a dedicated stream key:
# TRANSAK_STREAM_API_KEY=
# TRANSAK_PARTNER_ID=
# Coinbase Offramp (CDP). Get keys: https://portal.cdp.coinbase.com
# COINBASE_CDP_API_KEY_NAME=
# COINBASE_CDP_API_KEY_PRIVATE=
# COINBASE_OFFRAMP_ENVIRONMENT=sandbox

# ---- SWAP (same-chain / cross-token; non-custodial) ------------------------
# LI.FI (keyless-capable; set a key for higher limits). https://li.fi (portal).
# LIFI_API_KEY=
# LIFI_ENABLED=false                  # set true to wire keyless
# LIFI_INTEGRATOR=sardis              # CONFIG
# LIFI_FEE=                           # CONFIG: integrator fee fraction (e.g. 0.001)
# LIFI_ENVIRONMENT=staging
# 0x Swap API v2. Get keys: https://dashboard.0x.org
# ZEROX_API_KEY=
# ZEROX_SWAP_FEE_BPS=                 # CONFIG: integrator fee (bps)
# ZEROX_SWAP_FEE_RECIPIENT=           # CONFIG: fee recipient address
# ZEROX_ENVIRONMENT=sandbox
# Jupiter (Solana; keyless-capable). https://station.jup.ag/docs
# JUPITER_API_KEY=
# JUPITER_ENABLED=false
# JUPITER_PLATFORM_FEE_BPS=           # CONFIG
# JUPITER_FEE_ACCOUNT=                # CONFIG

# ---- BRIDGE (cross-chain; non-custodial) -----------------------------------
# Squid (intent-based; live on Tempo). Get integrator id: https://app.squidrouter.com
# SQUID_INTEGRATOR_ID=
# SQUID_ENVIRONMENT=staging           # staging | production
# SQUID_SLIPPAGE_PERCENT=1.0          # CONFIG
# CCTP v2 (canonical USDC burn/mint; keyless/public Iris). Opt-in:
# CCTP_ENABLED=false
# CCTP_FAST=true
# CCTP_ENVIRONMENT=sandbox

# ---- CARDS (virtual card issuing) ------------------------------------------
# Crossmint Agentic Cards (PRIMARY; non-custodial). Get keys: https://www.crossmint.com (console).
# CROSSMINT_API_KEY=
# CROSSMINT_RAIN_API_KEY=             # or RAIN_API_KEY
# CROSSMINT_ENVIRONMENT=sandbox       # sandbox | production
# Lithic card issuing (FALLBACK) reuses LITHIC_API_KEY (above).
# Stripe Issuing (FALLBACK). Get keys: https://dashboard.stripe.com
# STRIPE_ISSUING_API_KEY=             # or STRIPE_SECRET_KEY
# STRIPE_ISSUING_ENVIRONMENT=sandbox

# ---- KYC / KYB (identity verification) -------------------------------------
# Didit (primary). Get keys: https://business.didit.me (API key + workflow ids).
# DIDIT_API_KEY=
# DIDIT_KYC_WORKFLOW_ID=              # or DIDIT_WORKFLOW_ID
# DIDIT_KYB_WORKFLOW_ID=
# DIDIT_WEBHOOK_SECRET=
# DIDIT_CALLBACK_URL=                 # CONFIG (public redirect URL)
# DIDIT_ENVIRONMENT=sandbox           # sandbox | production

# ---- KYT / AML (transaction + address screening) — required-in-production --
# OpenSanctions (PREFERRED; raw address + counterparty). Get key: https://www.opensanctions.org/api
# OPENSANCTIONS_API_KEY=
# OPENSANCTIONS_SCOPE=default         # CONFIG
# OPENSANCTIONS_ALGORITHM=best        # CONFIG
# OPENSANCTIONS_THRESHOLD=0.7         # CONFIG (match score cutoff)
# OPENSANCTIONS_ENVIRONMENT=sandbox
# Didit KYT (FALLBACK) reuses DIDIT_API_KEY (above).

# --- NOTIFICATION (human-in-the-loop approval delivery; delivery only) -------
# First-configured-wins: Twilio, then Photon/Spectrum. Unconfigured => SIMULATED
# sandbox impl (dev/tests run with NO keys). Never decides an outcome.
#
# Twilio (PRIMARY): SMS/WhatsApp messaging + Verify OTP step-up for high-value.
# Get keys: https://console.twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=                  # or TWILIO_MESSAGING_SERVICE_SID
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_VERIFY_SERVICE_SID=           # enables OTP step-up
#
# Photon/Spectrum (agent-native omni-channel: iMessage/WhatsApp/Telegram/Slack).
# spectrum-ts message-send (the Approve/Deny poll) is TS-only, so Python relays
# through a thin Node sidecar that owns the SDK (see docs/providers.md).
# PHOTON_RELAY_URL=                    # or SPECTRUM_RELAY_URL — the Node sidecar
# PHOTON_RELAY_SECRET=                 # or SPECTRUM_RELAY_SECRET — shared HMAC-SHA256 secret
# PHOTON_PROJECT_ID=                   # or SPECTRUM_PROJECT_ID  — Spectrum Cloud control-plane
# PHOTON_PROJECT_SECRET=               # or SPECTRUM_PROJECT_SECRET (forwarded to sidecar)
#
# Approval decision signing (the MOAT — NOT delivery). Sardis signs every
# decision (approve/deny/expire) as tamper-evident HMAC-SHA256 evidence bound to
# the policy+mandate snapshot in effect at request time. REQUIRED in
# prod/staging (fail-closed: a missing key refuses to sign). Outside prod a
# 'dev-' fallback is used so dev/tests run with NO keys.
# SARDIS_APPROVAL_HMAC_KEY=
#
# =============================================================================
# PROGRAMMABLE RECOURSE (escrow / dispute window) — the RecourseHold primitive
# =============================================================================
# A payment can carry a policy-defined, time-boxed recourse window. After
# settlement the orchestrator opens a durable, signed RecourseHold: funds (or a
# claim) sit in the hold for the window, then resolve down ONE fail-closed path
# (released on expiry / refunded within window / disputed -> resolved). Sardis
# owns the decision + signed evidence (the moat); the escrow contract +
# reverse-transfer are swappable execution.
#
# Execution mode. 'noop' (default) records intent and moves NO real money —
# the hold state machine is the source of truth, so dev/tests need NO keys.
# 'live' wraps the vendored Circle RefundProtocol (Apache-2.0) but ONLY when a
# chain client is injected; otherwise it falls back to noop.
# SARDIS_RECOURSE_MODE=noop
#
# RefundProtocol contract used by the live executor (defaults to the per-chain
# SARDIS_<CHAIN>_REFUND_PROTOCOL_ADDRESS already configured below).
# SARDIS_REFUND_PROTOCOL_ADDRESS=
#
# Recourse decision signing (the MOAT — separate key from approvals). Every
# hold transition (open/release/refund/dispute/resolve) is signed as
# tamper-evident HMAC-SHA256 evidence bound to the policy+mandate snapshot at
# open time. REQUIRED in prod/staging (fail-closed: missing key refuses to
# sign). Outside prod a 'dev-' fallback runs with NO keys.
# SARDIS_RECOURSE_HMAC_KEY=

# =============================================================================
# PROPAGATING REVOCATION (the kill switch) — one revoke across every rail
# =============================================================================
# ONE revoke atomically propagates across EVERY rail: it marks the spending
# mandate(s) revoked (the authority root — the orchestrator then denies every
# future payment for it at execution time), freezes the agent's virtual cards
# (via the provider CardPort), revokes outstanding one-time spend objects, denies
# pending approvals (via the same signed ApprovalGate), and blocks in-flight
# payments — then returns a SIGNED, INDEPENDENTLY-VERIFIABLE proof-of-revocation
# listing exactly what was killed and when. No single rail-owner can build this;
# it requires neutrality across all rails. That is the moat.
#
# Fail-closed: a downstream kill that cannot be confirmed (e.g. a card-freeze
# provider error) is recorded 'blocked_pending' and the overall outcome is
# 'blocked_pending_downstream' — NEVER reported as fully 'propagated'. The
# authority is still denied at execution (the mandate is revoked), and a
# background reconcile sweep retries the blocked rails. Partial propagation is
# always told truthfully in the proof.
#
# Revocation proof signing (the MOAT — separate key from approvals/recourse).
# The proof's decision_hash binds the revocation identity + the FULL target list
# + the overall outcome + the timestamp; the signature is HMAC-SHA256 over it, so
# a tampered/truncated target list or a wrong key fails verification. Anyone with
# the key can verify a proof offline by POSTing it back to
# /api/v2/revocations/verify (no live-system access required). REQUIRED in
# prod/staging (fail-closed: a missing key refuses to sign or verify a proof).
# Outside prod a 'dev-' fallback runs with NO keys.
# SARDIS_REVOCATION_HMAC_KEY=

# =============================================================================
# ATTENUATED DELEGATION GRAPH (object-capability for money)
# =============================================================================
# An agent (or principal) delegates a SCOPED, BOUNDED, REVOCABLE slice of its own
# authority to a sub-agent, forming an attenuating capability chain — a delegate
# can NEVER exceed its delegator. Example: a human gives Agent A a $500 mandate;
# A delegates $50 (scoped to a subset of merchants) to sub-agent B; B delegates
# $20 to tool C. Every hop must narrow (cap <= parent remaining, expiry <= parent,
# scope subset of parent). Attenuation is enforced fail-closed at EVERY hop at
# mint time AND re-checked at EXECUTION time: a delegated payment re-walks the
# whole chain (each link non-revoked + within its cap/scope + non-expired); any
# break -> DENY. Revoking a parent propagates to the ENTIRE delegation subtree.
#
# DelegationEvidence signing (the MOAT — separate key). Each minted delegation
# carries an HMAC-SHA256 evidence whose decision_hash binds the delegation
# identity + the EXACT attenuated grant (cap, scope hash, expiry, depth), so a
# widened/tampered delegation fails verification (POST it to
# /api/v2/delegations/verify). REQUIRED in prod/staging (fail-closed: a missing
# key refuses to sign a delegation of authority). Outside prod a 'dev-' fallback
# runs with NO keys.
# SARDIS_DELEGATION_HMAC_KEY=

# =============================================================================
# PORTABLE PROOF-OF-AUTHORITY (offline-verifiable credential of authorization)
# =============================================================================
# A signed, self-contained credential proving an action WAS authorized by Sardis.
# Emitted on EVERY authorized execution, it binds policy_hash + mandate_hash +
# delegation_chain + decision + inputs. Unlike the HMAC proofs above, it is signed
# with Ed25519 (ASYMMETRIC) so a merchant / auditor / regulator can verify it
# OFFLINE with the PUBLISHED public key — without trusting or calling Sardis, and
# without ever being able to forge a proof. The published verification key is
# served at GET /api/v2/authority/proofs/jwk; verification at
# POST /api/v2/authority/proofs/verify (both PUBLIC, no auth).
#
# This is the Ed25519 PRIVATE seed Sardis signs with: a 32-byte seed encoded as
# hex (64 chars) or base64/base64url. REQUIRED in prod/staging (fail-closed: a
# missing key refuses to sign a portable Proof-of-Authority). Outside prod a
# deterministic dev seed is used. Generate one with:
#   python -c "import os; print(os.urandom(32).hex())"
# Keep the PRIVATE seed secret; only the derived PUBLIC key is ever published.
# SARDIS_AUTHORITY_PROOF_PRIVATE_KEY=

# =============================================================================
# GUARD — agent-fraud risk scoring (in-house decision + external signal feeds)
# =============================================================================
# Sardis owns the risk DECISION + policy (the moat). The in-house RiskEngine
# reuses the behavioral AnomalyEngine (amount-vs-budget deviation, velocity
# spikes, new-counterparty, off-pattern time/geo, compromised/rogue-agent
# signals) and COMBINES it with any configured external feeds below. External
# feeds only ever CONTRIBUTE A SIGNAL — they never decide allow/deny.
#
# The combined 0-100 score maps to a binding action, consulted by the
# orchestrator pre-dispatch on every money-moving execution:
#   < 30        -> ALLOW            (proceed)
#   30-59       -> FLAG             (allow + record the signal for review)
#   60-84       -> REQUIRE_APPROVAL (route to the ApprovalGate / human step-up)
#   >= 85       -> BLOCK            (deny, fail-closed; NO money moves)
# Fail-closed: an external feed that errors on a HIGH-VALUE tx (>= 1000) is
# never silently allowed — it escalates to REQUIRE_APPROVAL.
#
# Env-gated: with NO keys set, the RiskEngine runs INTERNAL-ONLY (the sandbox
# feed is excluded), so dev + tests run with no keys and never fail open. When
# BOTH keys are set, BOTH feeds are combined (they are complementary, not a
# winner-takes-all). Read surface: GET /api/v2/agents/{agent_id}/risk-signals.
#
# SEON (PRIMARY agent-fraud feed): device / email / IP / phone intelligence +
# fraud score 0-100 and state APPROVE/REVIEW/DECLINE. Scores on whatever subset
# Sardis can supply (agent id + amount at minimum). Auth header X-API-KEY.
# Get a key: https://seon.io  (docs.seon.io/api-reference/fraud-api)
# SEON_API_KEY=
# SEON_ENVIRONMENT=sandbox             # 'production' for the live host
# SEON_BASE_URL=https://api.seon.io    # US region: https://api.us-east-1-main.seon.io
#
# Stripe Radar (network risk on Stripe-processed card legs): reads
# charge.outcome risk_score (0-99, Radar for Fraud Teams) / risk_level
# (normal|elevated|highest) when a stripe_charge_id is in the signal context.
# Abstains (NOT_ASSESSED) for Sardis-native on-chain legs (no Stripe charge).
# Reuses the Stripe secret key; no separate Radar key exists.
# docs.stripe.com/radar/risk-evaluation
# STRIPE_RADAR_API_KEY=                 # falls back to STRIPE_SECRET_KEY above
# STRIPE_ENVIRONMENT=sandbox            # sk_live_ keys are treated as production
