# SARDIS_BASE_AGENT_REGISTRY_ADDRESS=0x...
# SARDIS_POLYGON_WALLET_FACTORY_ADDRESS=0x...
# SARDIS_POLYGON_LEDGER_ANCHOR_ADDRESS=0x...
# SARDIS_POLYGON_AGENT_REGISTRY_ADDRESS=0x...
# Phase 2 (post-audit):
# SARDIS_BASE_ESCROW_ADDRESS=0x...
# SARDIS_POLYGON_ESCROW_ADDRESS=0x...

# ---- Additional runtime env vars (auto-synced) ----
BRIDGE_CARDS_BASE_URL=
BRIDGE_CARDS_METHOD_MAP_JSON=
BRIDGE_CARDS_PATH_MAP_JSON=
BRIDGE_CARDS_WEBHOOK_SECRET=
