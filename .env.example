# =============================================================================
# Sardis SDK Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values. NEVER commit .env.
#
# This is the PUBLIC SDK surface. These variables configure the `sardis`
# Python client (and the framework integrations / MCP server that wrap it).
# Backend/service configuration (database, providers, signing, deploy) lives
# with the Sardis service and is not part of this open-source repository.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
# Your Sardis API key (create one in the Sardis dashboard).
SARDIS_API_KEY=sk_...

# -----------------------------------------------------------------------------
# Optional — API endpoint
# -----------------------------------------------------------------------------
# Override the API base URL (default: https://api.sardis.sh).
# Point this at your own deployment or a local reference server when testing.
# SARDIS_API_BASE_URL=https://api.sardis.sh

# Default chain for SDK operations that take an optional chain argument.
# SARDIS_DEFAULT_CHAIN=base

# -----------------------------------------------------------------------------
# Optional — agent identity (used by framework integrations / MCP tools)
# -----------------------------------------------------------------------------
# SARDIS_AGENT_ID=
# SARDIS_AGENT_NAME=
# SARDIS_WALLET_ID=

# -----------------------------------------------------------------------------
# Optional — client telemetry / batching
# -----------------------------------------------------------------------------
# SARDIS_TELEMETRY_ENABLED=true
# SARDIS_HEARTBEAT_INTERVAL=60
# SARDIS_BATCH_SIZE=100
# SARDIS_BATCH_INTERVAL=5
